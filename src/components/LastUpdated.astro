---
// Ejecutado en tiempo de BUILD → fecha se graba en el HTML estático
// Señal de frescura (Freshness SEO) para Googlebot
const hoy       = new Date();
const fechaISO  = hoy.toISOString().slice(0, 10);  // "2026-05-13"
const fechaLarga = new Intl.DateTimeFormat('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(hoy);
---

<span
  class="inline-flex items-center gap-1.5 text-gray-500 text-xs"
  title="Fecha en que se generó este contenido"
>
  <!-- Icono calendario -->
  <svg
    class="w-3 h-3 text-gold shrink-0"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-width="2"/>
    <line x1="16" y1="2" x2="16" y2="6" stroke-width="2"/>
    <line x1="8"  y1="2" x2="8"  y2="6" stroke-width="2"/>
    <line x1="3"  y1="10" x2="21" y2="10" stroke-width="2"/>
  </svg>

  Actualizado:&nbsp;
  <time datetime={fechaISO} class="font-medium text-gray-400">
    {fechaLarga}
  </time>
</span>
