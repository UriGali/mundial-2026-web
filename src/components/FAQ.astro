---
interface FAQItem {
  q: string;
  a: string;
}
interface Props {
  items: FAQItem[];
  heading?: string;
  sub?: string;
}
const {
  items,
  heading = 'Preguntas Frecuentes',
  sub = 'Todo lo que necesitas saber',
} = Astro.props;
---

<section class="py-16 px-4 sm:px-6 lg:px-8" aria-labelledby="faq-cmp-heading">
  <div class="max-w-3xl mx-auto">

    <div class="text-center mb-10">
      <p class="font-oswald text-xs uppercase tracking-[0.2em] text-gold mb-2">{sub}</p>
      <h2
        id="faq-cmp-heading"
        class="font-oswald font-bold text-white"
        style="font-size: clamp(1.6rem, 4vw, 2.4rem);"
      >{heading}</h2>
    </div>

    <div class="space-y-2">
      {items.map(({ q, a }) => (
        <details
          class="group rounded-2xl overflow-hidden border transition-all duration-200"
          style="background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08);"
        >
          <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none select-none">
            <span class="font-oswald font-semibold text-white text-base sm:text-lg pr-2 leading-tight">{q}</span>
            <svg
              class="w-5 h-5 shrink-0 transition-transform duration-300 group-open:rotate-180 text-gold"
              fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1 text-sm text-slate-400 leading-relaxed border-t" style="border-color: rgba(255,255,255,0.05);">
            {a}
          </div>
        </details>
      ))}
    </div>

  </div>
</section>
