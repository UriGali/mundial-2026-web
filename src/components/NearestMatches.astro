---
// Data comes from the single source of truth — no inline duplicate
import { MATCHES } from '../data/matches';
---

<section class="py-16 px-4 sm:px-6 lg:px-8" aria-labelledby="proximos-heading">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-10">
      <p class="font-oswald text-xs tracking-[0.2em] text-gold uppercase mb-2">CUENTA REGRESIVA EN VIVO</p>
      <h2
        id="proximos-heading"
        class="font-oswald font-bold text-white mb-3"
        style="font-size: clamp(1.6rem, 4vw, 2.5rem);"
      >
        Próximos Partidos del Mundial 2026
      </h2>
      <p id="nxt-tz" class="text-slate-500 text-sm font-mono h-5"></p>
    </div>

    <!-- Match cards rendered by JS -->
    <div
      id="nxt-grid"
      class="grid gap-4 sm:grid-cols-3"
      aria-live="polite"
      aria-label="Próximos partidos del Mundial 2026"
    >
      <div class="sm:col-span-3 flex items-center justify-center py-14 text-slate-700">
        <span class="font-mono text-sm animate-pulse">Cargando partidos...</span>
      </div>
    </div>

    <div class="text-center mt-10">
      <a
        href="/calendario"
        class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-gold transition-colors font-mono border border-slate-700 hover:border-gold/40 px-5 py-2.5 rounded-full"
      >
        Ver calendario completo →
      </a>
    </div>

  </div>
</section>

<!-- define:vars serialises MATCHES to JSON and injects it as a plain JS variable -->
<script define:vars={{ MATCHES }}>
  function pad2(n) { return String(n).padStart(2, '0'); }

  function countdown(ms) {
    if (ms <= 0) return { d: 0, h: 0, m: 0, s: 0 };
    const t = Math.floor(ms / 1000);
    return { d: Math.floor(t / 86400), h: Math.floor((t % 86400) / 3600), m: Math.floor((t % 3600) / 60), s: t % 60 };
  }

  function getNext3() {
    const now = Date.now();
    const seen = new Set();
    return MATCHES
      .filter(m => {
        const t = new Date(m.utc).getTime();
        if (t <= now || seen.has(m.utc)) return false;
        seen.add(m.utc);
        return true;
      })
      .sort((a, b) => new Date(a.utc).getTime() - new Date(b.utc).getTime())
      .slice(0, 3);
  }

  function renderCards(next3, tz) {
    if (next3.length === 0) {
      return `<div class="sm:col-span-3 text-center text-slate-600 py-12 font-mono text-sm">
        El Mundial 2026 ha concluido. ¡Gracias por seguirlo con nosotros! ⚽
      </div>`;
    }

    return next3.map(m => {
      const mt     = new Date(m.utc);
      const lTime  = mt.toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit', timeZone: tz, hour12: false });
      const lDate  = mt.toLocaleDateString('es', { weekday: 'short', day: 'numeric', month: 'short', timeZone: tz });
      const { d, h, m: mn, s } = countdown(mt.getTime() - Date.now());
      const isFinal  = m.id === 'f01';
      const border   = isFinal ? 'border-gold/50' : 'border-slate-700/60';
      const faseCls  = isFinal ? 'bg-gold/20 text-gold' : 'bg-slate-800 text-green-400';
      const sedeName = m.sedeSlug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

      return `
<div class="group flex flex-col bg-slate-900 border ${border} hover:border-gold/40 rounded-2xl overflow-hidden transition-all hover:shadow-[0_0_28px_rgba(212,175,55,0.1)]">
  <div class="px-4 py-2.5 border-b border-slate-800 flex items-center justify-between">
    <span class="font-oswald text-[10px] tracking-[0.15em] uppercase ${faseCls} px-2 py-0.5 rounded">${m.fase}</span>
    <span class="text-slate-600 font-mono text-[10px]">${lDate} · ${lTime}</span>
  </div>
  <div class="px-4 py-5 flex items-center justify-between gap-2 flex-1">
    <div class="text-center flex-1 min-w-0">
      <div class="text-3xl mb-1.5">${m.f1}</div>
      <div class="text-white font-semibold text-xs leading-tight truncate">${m.e1}</div>
    </div>
    <div class="shrink-0 px-2 text-slate-600 font-mono text-xs font-bold">VS</div>
    <div class="text-center flex-1 min-w-0">
      <div class="text-3xl mb-1.5">${m.f2}</div>
      <div class="text-white font-semibold text-xs leading-tight truncate">${m.e2}</div>
    </div>
  </div>
  <div class="px-4 pb-4">
    <div class="bg-black/50 border border-slate-800 rounded-xl p-2.5 grid grid-cols-4 gap-1 text-center" data-utc="${m.utc}">
      <div><div class="font-mono font-bold text-green-400 tabular-nums text-base count-d">${pad2(d)}</div><div class="text-slate-600 text-[8px] uppercase tracking-wider mt-0.5">días</div></div>
      <div><div class="font-mono font-bold text-green-400 tabular-nums text-base count-h">${pad2(h)}</div><div class="text-slate-600 text-[8px] uppercase tracking-wider mt-0.5">h</div></div>
      <div><div class="font-mono font-bold text-green-400 tabular-nums text-base count-m">${pad2(mn)}</div><div class="text-slate-600 text-[8px] uppercase tracking-wider mt-0.5">min</div></div>
      <div><div class="font-mono font-bold text-green-400 tabular-nums text-base count-s">${pad2(s)}</div><div class="text-slate-600 text-[8px] uppercase tracking-wider mt-0.5">seg</div></div>
    </div>
  </div>
  <div class="px-4 pb-2">
    <a href="/partidos/${m.id}" class="flex items-center justify-center gap-2 text-xs font-mono bg-gold/10 hover:bg-gold/20 text-gold border border-gold/20 hover:border-gold/50 rounded-xl py-2.5 transition-all font-semibold">
      Ver partido completo →
    </a>
  </div>
  <a href="/sedes/${m.sedeSlug}" class="px-4 pb-4 flex items-center justify-between text-xs font-mono transition-colors text-slate-600 hover:text-gold">
    <span>${sedeName}</span>
    <span class="text-gold group-hover:underline">Ver sede →</span>
  </a>
</div>`;
    }).join('');
  }

  function init() {
    const tz   = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const tzEl = document.getElementById('nxt-tz');
    const grid = document.getElementById('nxt-grid');
    if (tzEl) tzEl.textContent = `Tu hora local: ${tz}`;
    const next3 = getNext3();
    if (grid) grid.innerHTML = renderCards(next3, tz);
  }

  init();

  setInterval(() => {
    document.querySelectorAll('[data-utc]').forEach(el => {
      const utc = el.dataset.utc;
      const ms  = new Date(utc).getTime() - Date.now();
      if (ms <= 0) { init(); return; }
      const { d, h, m, s } = countdown(ms);
      el.querySelector('.count-d').textContent = pad2(d);
      el.querySelector('.count-h').textContent = pad2(h);
      el.querySelector('.count-m').textContent = pad2(m);
      el.querySelector('.count-s').textContent = pad2(s);
    });
  }, 1000);
</script>
