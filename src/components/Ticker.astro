---
const items = [
  '⚽  MUNDIAL FIFA 2026 — 11 JUNIO AL 19 JULIO',
  '🏆  GRAN FINAL: METLIFE STADIUM · NUEVA YORK · 19 JULIO',
  '🇲🇽  ESTADIO AZTECA — TERCER MUNDIAL EN SU HISTORIA',
  '🎲  SORTEO DE GRUPOS: MIAMI · ENERO 2026',
  '⭐  48 SELECCIONES · 16 CIUDADES · 3 PAÍSES · 104 PARTIDOS',
  '🎫  ENTRADAS SOLO EN EL PORTAL OFICIAL FIFA.COM',
  '🇺🇸  SEMIFINAL · NRG STADIUM, HOUSTON · 17 JULIO',
  '🌎  EL TORNEO MÁS GRANDE EN LA HISTORIA DEL FÚTBOL',
  '🇨🇦  CANADA SEDE POR PRIMERA VEZ EN UN MUNDIAL',
  '🇪🇸  ESPAÑA · CAMPEONA DEFENSORA — TRES VECES CAMPEONA DEL MUNDO',
];
---

<div
  class="overflow-hidden relative z-40"
  style="background: linear-gradient(90deg, #b8922a 0%, #d4af37 20%, #f5d97a 50%, #d4af37 80%, #b8922a 100%);"
  aria-label="Noticias del Mundial 2026"
>
  <!-- Fade izquierda -->
  <div
    class="absolute left-0 top-0 bottom-0 w-20 z-10 pointer-events-none"
    style="background: linear-gradient(90deg, #b8922a, transparent);"
    aria-hidden="true"
  ></div>
  <!-- Fade derecha -->
  <div
    class="absolute right-0 top-0 bottom-0 w-20 z-10 pointer-events-none"
    style="background: linear-gradient(270deg, #b8922a, transparent);"
    aria-hidden="true"
  ></div>

  <div class="flex whitespace-nowrap animate-ticker py-1.5" aria-hidden="true">
    {[...items, ...items].map((item) => (
      <span class="inline-flex items-center shrink-0">
        <span class="font-oswald font-semibold text-[11px] tracking-[0.18em] text-slate-950 uppercase px-5">
          {item}
        </span>
        <span class="text-slate-950/25 text-[10px] shrink-0">◆</span>
      </span>
    ))}
  </div>
</div>
