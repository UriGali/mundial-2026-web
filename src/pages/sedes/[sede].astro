            <div class="flex gap-4">
              <span class="text-3xl shrink-0 mt-0.5" aria-hidden="true">{t.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class="font-bold text-navy-900 text-base sm:text-lg mb-1">{t.metodo}</h3>
                <p class="text-gray-600 text-sm mb-3 leading-relaxed">{t.descripcion}</p>
                <p class="text-gray-700 text-sm leading-relaxed bg-gray-50 rounded-xl p-3 mb-3">{t.detalle}</p>
                <div class="flex flex-wrap gap-3">
                  <span class="inline-flex items-center gap-1.5 bg-navy-900/5 text-navy-900 text-xs font-medium px-3 py-1.5 rounded-full">
                    <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
