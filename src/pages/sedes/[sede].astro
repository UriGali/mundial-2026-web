              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>{fanZone.ubicacion}</span>
          </div>
        </div>

        <!-- Descripción -->
        <div class="px-6 sm:px-8 py-6 border-b border-white/10">
          <p class="text-gray-300 text-base leading-relaxed">{fanZone.descripcion}</p>
        </div>

        <!-- Features -->
        <div class="px-6 sm:px-8 py-6">
          <p class="font-semibold text-gold text-xs uppercase tracking-widest mb-5">Qué encontrarás</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {fanZone.features.map(feature => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <span class="text-base leading-none mt-0.5 shrink-0" aria-hidden="true">{feature.split(' ')[0]}</span>
                <span>{feature.split(' ').slice(1).join(' ')}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- AdSlot al final de la guía -->
    <AdSlot slot="7788990011" format="rectangle" label="Publicidad" />

  </div>

  <!-- ===================================================
       NOTICIAS RELACIONADAS — tag-matched sedes
  ==================================================== -->
  <section
    class="py-14 px-4 sm:px-6 lg:px-8 border-t border-white/5"
    style="background:rgba(255,255,255,0.015);"
    aria-labelledby="relacionadas-heading"
  >
    <div class="max-w-4xl mx-auto">
      <h2
        id="relacionadas-heading"
        class="font-oswald font-bold text-xl text-white mb-2 flex items-center gap-2"
      >
        <span
          class="w-1 h-6 rounded inline-block"
          style="background:linear-gradient(180deg,#f5d97a,#d4af37);"
          aria-hidden="true"
        ></span>
        Sedes relacionadas
      </h2>
      <p class="text-slate-500 text-sm mb-8">
        Estadios con características similares a {ciudad} — mismo país, fase o aforo.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {relacionadas.map((r, idx) => (
          <a
            href={`/sedes/${r.slug}`}
            class="group block bg-slate-900/60 border border-slate-800 hover:border-gold/40 rounded-2xl overflow-hidden transition-all hover:shadow-[0_0_20px_rgba(212,175,55,0.08)]"
          >
            <!-- Placeholder image with overlay -->
            <div class="relative h-32 overflow-hidden">
              <img
                src={`https://picsum.photos/seed/${r.slug}-rel/480/200`}
                alt={r.estadio}
                width="480" height="200"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div
                class="absolute inset-0"
                style="background:linear-gradient(180deg,transparent 30%,rgba(2,6,23,0.9) 100%);"
                aria-hidden="true"
              ></div>
              <span class={`absolute top-2 right-2 text-[10px] font-oswald tracking-wider px-2 py-0.5 rounded text-white ${r.faseClass}`}>
                {r.fase}
              </span>
            </div>
            <!-- Content -->
            <div class="px-4 py-3">
              <p class="text-xs text-slate-500 font-mono mb-1">{r.flag} {r.pais}</p>
              <h3 class="font-oswald font-bold text-white group-hover:text-gold transition-colors text-base leading-tight">
                {r.ciudad}
              </h3>
              <p class="text-slate-500 text-xs mt-0.5 leading-snug">{r.estadio}</p>
              <div class="flex items-center justify-between mt-2">
                <span class="text-slate-600 font-mono text-xs">{r.capacidad} aforo</span>
                <span class="text-gold text-xs font-mono group-hover:underline">Ver sede →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Also link to calendar and horarios -->
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/calendario"
          class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-gold border border-slate-700/60 hover:border-gold/40 px-4 py-2 rounded-full transition-all"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="2"/>
            <line x1="16" y1="2" x2="16" y2="6" stroke-width="2"/>
            <line x1="8" y1="2" x2="8" y2="6" stroke-width="2"/>
            <line x1="3" y1="10" x2="21" y2="10" stroke-width="2"/>
          </svg>
          Calendario de partidos
        </a>
        <a
          href="/horarios/mexico/ciudad-de-mexico"
          class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-gold border border-slate-700/60 hover:border-gold/40 px-4 py-2 rounded-full transition-all"
        >
          🕐 Horarios en tu zona
        </a>
        <a
          href="/grupos"
          class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-gold border border-slate-700/60 hover:border-gold/40 px-4 py-2 rounded-full transition-all"
        >
          ⚽ Grupos del Mundial
        </a>
      </div>
    </div>
  </section>

  <!-- ===================================================
       NAVEGACIÓN ENTRE SEDES
  ==================================================== -->
  <section class="bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 mt-8" aria-labelledby="otras-sedes-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="otras-sedes-heading" class="font-black text-xl text-navy-900 mb-6 text-center">
        Otras sedes del Mundial 2026
      </h2>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { href: '/sedes/ciudad-de-mexico', label: '🇲🇽 Ciudad de México' },
          { href: '/sedes/monterrey',        label: '🇲🇽 Monterrey' },
          { href: '/sedes/guadalajara',      label: '🇲🇽 Guadalajara' },
          { href: '/sedes/nueva-york',       label: '🇺🇸 Nueva York' },
          { href: '/sedes/los-angeles',      label: '🇺🇸 Los Ángeles' },
          { href: '/sedes/dallas',           label: '🇺🇸 Dallas' },
          { href: '/sedes/san-francisco',    label: '🇺🇸 San Francisco' },
          { href: '/sedes/seattle',          label: '🇺🇸 Seattle' },
          { href: '/sedes/miami',            label: '🇺🇸 Miami' },
          { href: '/sedes/atlanta',          label: '🇺🇸 Atlanta' },
          { href: '/sedes/boston',           label: '🇺🇸 Boston' },
          { href: '/sedes/kansas-city',      label: '🇺🇸 Kansas City' },
          { href: '/sedes/filadelfia',       label: '🇺🇸 Filadelfia' },
          { href: '/sedes/houston',          label: '🇺🇸 Houston' },
          { href: '/sedes/vancouver',        label: '🇨🇦 Vancouver' },
          { href: '/sedes/toronto',          label: '🇨🇦 Toronto' },
        ]
          .filter(s => s.href !== `/sedes/${slug}`)
          .map(s => (
            <a
              href={s.href}
              class="bg-white border border-gray-200 hover:border-gold hover:text-gold text-gray-700 text-sm font-medium px-5 py-2.5 rounded-full transition-all shadow-sm"
            >
              {s.label}
            </a>
          ))
        }
        <a
          href="/sedes"
          class="bg-navy-900 text-white text-sm font-bold px-5 py-2.5 rounded-full hover:bg-navy-800 transition-colors shadow-sm"
        >
          Ver las 16 sedes →
        </a>
      </div>
    </div>
  </section>

</Layout>
