// ── Interfaces ────────────────────────────────────────────────────────────────
interface Transporte {
  icon: string;
  metodo: string;
  descripcion: string;
  detalle: string;
  tiempo: string;
  costo: string;
}

interface Hotel {
  nombre: string;
  estrellas: number;
  precio: string;
  distancia: string;
  descripcion: string;
  badge: string;
  badgeClass: string;
}

interface FanZone {
  nombre: string;
  ubicacion: string;
  descripcion: string;
  capacidad: string;
  horario: string;
  features: string[];
}

interface SedeData {
  slug: string;
  ciudad: string;
  pais: string;
  flag: string;
  estadio: string;
  capacidad: string;
  fase: string;
  faseClass: string;
  heroGradient: string;
  descripcion: string;
  intro: [string, string];
  transportes: Transporte[];
  hoteles: Hotel[];
  fanZone: FanZone;
  coords: { lat: number; lng: number };
  address: string;
  mapsQuery: string;
}

// ── getStaticPaths ─────────────────────────────────────────────────────────────
export function getStaticPaths() {
  // computeTags must live inside getStaticPaths due to Astro SSG isolation
  function computeTags(s: SedeData): string[] {
    const tags: string[] = [];
    if      (s.pais === 'México') tags.push('mexico');
    else if (s.pais === 'Canadá') tags.push('canada');
    else                          tags.push('usa');
    const f = s.fase.toLowerCase();
    if (f.includes('final') && !f.includes('semi') && !f.includes('cuarto')) tags.push('final');
    if (f.includes('semi'))   tags.push('semifinal');
    if (f.includes('cuarto')) tags.push('cuartos');
    if (f.includes('octavo')) tags.push('octavos');
    if (f.includes('ronda'))  tags.push('ronda32');
    if (f.includes('grupo'))  tags.push('grupos');
    const cap = parseInt(s.capacidad.replace(/,/g, ''), 10);
    tags.push(cap >= 75_000 ? 'grande' : cap >= 60_000 ? 'mediano' : 'pequeño');
    return tags;
  }
