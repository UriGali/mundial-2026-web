        <div class="bg-white/10 border border-white/20 rounded-full px-5 py-2 text-sm">
          <span class="text-gold font-black">{capacidad}</span>
          <span class="text-gray-300 ml-1">espectadores</span>
        </div>
        <div class="bg-white/10 border border-white/20 rounded-full px-5 py-2 text-sm">
          <span class="text-gold font-black">{fase}</span>
        </div>
        <a
          href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white/10 border border-white/20 rounded-full px-5 py-2 text-sm text-gray-300 hover:text-gold transition-colors flex items-center gap-1.5"
          aria-label={`Ver ${estadio} en Google Maps`}
        >
