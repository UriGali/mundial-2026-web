  },
  ];

  return sedesData.map(sede => {
    const myTags      = computeTags(sede);
    const relacionadas = sedesData
      .filter(s => s.slug !== sede.slug)
      .map(s => ({ ...s, score: computeTags(s).filter(t => myTags.includes(t)).length }))
      .sort((a, b) => b.score - a.score)
      .slice(0, 3)
      .map(({ slug, ciudad, pais, flag, estadio, fase, capacidad, faseClass }) =>
        ({ slug, ciudad, pais, flag, estadio, fase, capacidad, faseClass })
      );
    return {
      params: { sede: sede.slug },
      props:  { sede, relacionadas },
    };
  });
}

// ── Props de la página activa ──────────────────────────────────────────────────
type RelatedSede = { slug: string; ciudad: string; pais: string; flag: string; estadio: string; fase: string; capacidad: string; faseClass: string };
interface Props { sede: SedeData; relacionadas: RelatedSede[] }
const { sede, relacionadas } = Astro.props;

const {
  slug, ciudad, pais, flag, estadio, capacidad, fase, faseClass,
  heroGradient, descripcion, intro, transportes, hoteles, fanZone,
  coords, mapsQuery,
} = sede;

const title        = `${ciudad} — Sede Mundial 2026 | ${estadio}, Transporte y Hoteles`;
const description  = `Guía completa de ${ciudad} como sede del Mundial FIFA 2026: ${estadio} (cap. ${capacidad}), cómo llegar en metro/autobús/rideshare, mejores hoteles cercanos y la Fan Zone oficial.`;
const canonicalURL = `https://mundial2026guia.com/sedes/${slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'EventVenue',
      '@id': `https://mundial2026guia.com/sedes/${slug}#venue`,
      name: estadio,
      description: descripcion,
      url: canonicalURL,
      address: {
        '@type': 'PostalAddress',
        streetAddress: sede.address,
        addressLocality: ciudad,
        addressCountry: pais === 'México' ? 'MX' : pais === 'Canadá' ? 'CA' : 'US',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude:  coords.lat,
        longitude: coords.lng,
      },
      maximumAttendeeCapacity: parseInt(capacidad.replace(/,/g, ''), 10),
      event: {
        '@type': 'SportsEvent',
        name: 'Copa Mundial de Fútbol FIFA 2026',
        startDate: '2026-06-11',
        endDate: '2026-07-19',
        organizer: { '@type': 'Organization', name: 'FIFA' },
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://mundial2026guia.com/' },
        { '@type': 'ListItem', position: 2, name: 'Sedes',  item: 'https://mundial2026guia.com/sedes' },
        { '@type': 'ListItem', position: 3, name: ciudad,   item: canonicalURL },
      ],
    },
  ],
};
---

<Layout {title} {description} {canonicalURL} {jsonLd}>

  <!-- ===================================================
       HERO DE LA SEDE
  ==================================================== -->
  <section
    class="relative text-white overflow-hidden"
    style={`background: ${heroGradient}`}
    aria-labelledby="sede-heading"
  >
    <!-- Patrón decorativo -->
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true"
      style="background-image:radial-gradient(circle,#d4af37 1px,transparent 1px);background-size:32px 32px;">
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center">

      <!-- Badge fase -->
      <div class="inline-flex items-center gap-2 mb-5">
        <span class={`${faseClass} text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wide`}>
          {fase}
        </span>
      </div>

      <!-- Flag + City -->
      <div class="flex items-center justify-center gap-3 mb-3">
        <span class="text-5xl sm:text-6xl" role="img" aria-label={pais}>{flag}</span>
      </div>
      <h1 id="sede-heading" class="font-black text-4xl sm:text-6xl lg:text-7xl leading-none tracking-tight mb-2">
        {ciudad}
