      <ol class="flex items-center gap-1.5 flex-wrap">
        <li><a href="/" class="hover:text-gold transition-colors">Inicio</a></li>
        <li aria-hidden="true"><span class="text-gray-300">/</span></li>
        <li><a href="/sedes" class="hover:text-gold transition-colors">Sedes</a></li>
        <li aria-hidden="true"><span class="text-gray-300">/</span></li>
        <li class="text-navy-900 font-medium" aria-current="page">{ciudad}</li>
      </ol>
    </nav>

    <!-- ─── Introducción ──────────────────────────────────────────────────── -->
    <section class="mt-8" aria-labelledby="intro-heading">
      <h2 id="intro-heading" class="sr-only">Introducción a {ciudad}</h2>

      <!-- Párrafo 1 -->
      <p class="text-gray-700 text-lg leading-relaxed mb-6">{intro[0]}</p>

      <!-- Párrafo 2 -->
      <p class="text-gray-700 text-lg leading-relaxed mb-2">{intro[1]}</p>
    </section>

    <!-- AdSlot DESPUÉS del 2.º párrafo de la guía -->
    <AdSlot slot="3344556677" format="horizontal" label="Publicidad" />

    <!-- ─── Guía de Transporte ────────────────────────────────────────────── -->
