                    <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                    {t.costo}
                  </span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ─── Hoteles Cercanos ──────────────────────────────────────────────── -->
    <section class="mt-16" aria-labelledby="hoteles-heading">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-8 bg-gold rounded-full" aria-hidden="true"></div>
