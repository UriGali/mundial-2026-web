      <!-- Descripción -->
      <p class="text-gray-300 text-base sm:text-lg max-w-3xl mx-auto leading-relaxed">
        {descripcion}
      </p>
    </div>
  </section>

  <!-- ===================================================
       CONTENIDO PRINCIPAL
  ==================================================== -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Breadcrumb -->
