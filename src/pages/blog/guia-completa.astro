---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';

const title       = 'Guía Completa del Mundial 2026: Fechas, Sedes, Entradas y Más';
const description = 'Todo lo que necesitas saber sobre el Mundial FIFA 2026: cuándo empieza, dónde se juega, cómo comprar entradas, equipos clasificados, horarios y la guía de viaje definitiva.';
const keywords    = 'guia completa mundial 2026, copa del mundo 2026, cuando es el mundial 2026, donde se juega el mundial 2026, entradas mundial 2026 como comprar, sedes mundial 2026, equipos clasificados mundial 2026, horarios mundial 2026, final mundial 2026';
const canonicalURL = 'https://mundial26horarios.com/blog/guia-completa';

const datePublished = '2026-05-13';
const dateModified  = '2026-05-13';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://mundial26horarios.com/' },
        { '@type': 'ListItem', position: 2, name: 'Blog',   item: 'https://mundial26horarios.com/blog' },
        { '@type': 'ListItem', position: 3, name: 'Guía Completa del Mundial 2026', item: canonicalURL },
      ],
    },
    {
      '@type': 'Article',
      headline: title,
      description,
      datePublished,
      dateModified,
      url: canonicalURL,
      image: 'https://mundial26horarios.com/og-image.jpg',
      author: { '@type': 'Organization', name: 'Mundial 2026 Guía', url: 'https://mundial26horarios.com' },
      publisher: { '@type': 'Organization', name: 'Mundial 2026 Guía', url: 'https://mundial26horarios.com' },
      inLanguage: 'es',
      about: { '@type': 'SportsEvent', name: 'Copa Mundial de Fútbol FIFA 2026', startDate: '2026-06-11', endDate: '2026-07-19' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: '¿Cuándo empieza el Mundial 2026?',                     acceptedAnswer: { '@type': 'Answer', text: 'El Mundial FIFA 2026 comienza el jueves 11 de junio de 2026 con el partido inaugural México vs Ecuador en el Estadio Azteca de Ciudad de México.' } },
        { '@type': 'Question', name: '¿Cuánto duran los partidos del Mundial 2026?',          acceptedAnswer: { '@type': 'Answer', text: 'Cada partido del Mundial dura 90 minutos reglamentarios más descuentos. En eliminatorias, si hay empate, se juegan 2 tiempos de 15 minutos extra y, si persiste, tanda de penaltis.' } },
        { '@type': 'Question', name: '¿Dónde se juega la Final del Mundial 2026?',            acceptedAnswer: { '@type': 'Answer', text: 'La Gran Final se celebra el domingo 19 de julio de 2026 en el MetLife Stadium de East Rutherford, Nueva Jersey (área metropolitana de Nueva York), a las 22:00 UTC.' } },
        { '@type': 'Question', name: '¿Cuántos equipos juegan el Mundial 2026?',              acceptedAnswer: { '@type': 'Answer', text: '48 selecciones nacionales, agrupadas en 12 grupos de 4 equipos. Clasifican los dos primeros de cada grupo más los ocho mejores terceros a una Ronda de 32 (eliminatorias directas).' } },
        { '@type': 'Question', name: '¿Cómo comprar entradas para el Mundial 2026?',          acceptedAnswer: { '@type': 'Answer', text: 'Solo a través del portal oficial FIFA.com. Pasos: 1) Crea tu FIFA ID, 2) Selecciona los partidos deseados, 3) Elige la categoría de asiento, 4) Paga con tarjeta de crédito. Las entradas son nominales e intransferibles.' } },
        { '@type': 'Question', name: '¿En qué países se juega el Mundial 2026?',              acceptedAnswer: { '@type': 'Answer', text: 'En tres países simultáneamente: Estados Unidos (11 sedes), México (3 sedes: Ciudad de México, Guadalajara y Monterrey) y Canadá (2 sedes: Toronto y Vancouver).' } },
      ],
    },
  ],
};

// Tabla de contenidos
const toc = [
  { id: 'fechas',    label: '¿Cuándo es el Mundial 2026?' },
  { id: 'donde',     label: '¿Dónde se juega?' },
  { id: 'sedes',     label: 'Las 16 sedes oficiales' },
  { id: 'formato',   label: 'Formato: 48 equipos y 12 grupos' },
  { id: 'entradas',  label: 'Cómo comprar entradas' },
  { id: 'horarios',  label: 'Horarios por zona horaria' },
  { id: 'final',     label: 'La Gran Final: Nueva York 2026' },
  { id: 'favoritos', label: 'Equipos favoritos al título' },
  { id: 'faq',       label: 'Preguntas frecuentes' },
];
---

<Layout {title} {description} {keywords} {canonicalURL} {jsonLd}>

  <!-- ═══════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════ -->
  <section
    class="relative text-white py-14 sm:py-20 px-4 overflow-hidden"
    style="background:linear-gradient(160deg,#020617 0%,#0a1628 50%,#020617 100%);"
  >
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style="background-image:linear-gradient(rgba(212,175,55,0.8) 1px,transparent 1px),linear-gradient(90deg,rgba(212,175,55,0.8) 1px,transparent 1px);background-size:40px 40px;"
      aria-hidden="true"
    ></div>
    <div class="max-w-4xl mx-auto relative z-10">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-xs font-mono text-slate-600 flex" aria-label="Migas de pan">
        <ol class="flex items-center gap-1.5 flex-wrap">
          <li><a href="/" class="hover:text-gold transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-700">/</li>
          <li class="text-slate-400" aria-current="page">Guía Completa</li>
        </ol>
      </nav>

      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="bg-gold/20 text-gold border border-gold/30 font-oswald text-[10px] tracking-[0.2em] uppercase px-3 py-1 rounded-full">
          Guía Oficial
        </span>
        <span class="text-slate-500 font-mono text-xs">Actualizado: 13 mayo 2026</span>
        <span class="text-slate-600 font-mono text-xs">· 12 min de lectura</span>
      </div>

      <h1
        class="font-oswald font-bold text-white leading-tight mb-5"
        style="font-size:clamp(1.9rem,5.5vw,3.2rem);"
      >
        Guía Completa del Mundial FIFA 2026:<br class="hidden sm:block" />
        <span
          class="bg-clip-text text-transparent"
          style="background-image:linear-gradient(105deg,#b8922a 0%,#d4af37 40%,#f5d97a 60%,#d4af37 80%,#b8922a 100%);"
        > Todo lo que Necesitas Saber</span>
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-3xl">
        Fechas, sedes, equipos clasificados, cómo comprar entradas y los horarios convertidos a tu zona horaria. La guía más completa en español para el torneo de fútbol más grande de la historia.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       CONTENIDO + SIDEBAR
  ════════════════════════════════════════════════════ -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">

      <!-- ── ARTÍCULO ────────────────────────────────────────────────── -->
      <article class="min-w-0 prose-invert" aria-label="Guía completa del Mundial 2026">

        <!-- ── TABLA DE CONTENIDOS (mobile) ───────────────────── -->
        <nav
          class="lg:hidden bg-slate-900/60 border border-slate-700/60 rounded-2xl p-5 mb-10"
          aria-label="Tabla de contenidos"
        >
          <p class="font-oswald text-xs tracking-[0.2em] uppercase text-gold mb-3">En este artículo</p>
          <ol class="space-y-1.5">
            {toc.map((item, i) => (
              <li>
                <a href={`#${item.id}`} class="flex items-center gap-2 text-slate-400 hover:text-gold text-sm transition-colors group">
                  <span class="font-mono text-[10px] text-slate-600 group-hover:text-gold/60 w-5 shrink-0">{String(i+1).padStart(2,'0')}</span>
                  {item.label}
                </a>
              </li>
            ))}
          </ol>
        </nav>

        <!-- ════════════════════════════════════════════════════
             1. FECHAS
        ════════════════════════════════════════════════════ -->
        <section id="fechas" class="mb-12 scroll-mt-24">
          <h2 class="font-oswald font-bold text-white text-2xl sm:text-3xl mb-4 flex items-center gap-2">
            <span class="w-1 h-7 rounded" style="background:linear-gradient(180deg,#f5d97a,#d4af37);" aria-hidden="true"></span>
            ¿Cuándo es el Mundial 2026? Fechas Oficiales
          </h2>
          <p class="text-slate-300 leading-relaxed mb-4">
            El <strong class="text-white">Mundial FIFA 2026</strong> se celebra del <strong class="text-gold">11 de junio al 19 de julio de 2026</strong>, con un total de 39 días de competición. Es el torneo de fútbol más largo y con más equipos de la historia.
          </p>

          <!-- Key dates card -->
          <div class="grid sm:grid-cols-2 gap-3 my-6">
            {[
              { icon:'🟢', label:'Partido inaugural',     date:'11 jun 2026', detalle:'México vs Ecuador — Estadio Azteca' },
              { icon:'⚔️', label:'Inicio Fase de Grupos', date:'11 jun 2026', detalle:'Primeros 8 días: 3 partidos/día' },
              { icon:'🔥', label:'Ronda de 32',           date:'4 jul 2026',  detalle:'Primera eliminatoria directa' },
              { icon:'🏆', label:'Gran Final',             date:'19 jul 2026', detalle:'MetLife Stadium — 22:00 UTC' },
            ].map(d => (
              <div class="flex gap-3 bg-slate-900/60 border border-slate-800 rounded-xl p-4">
                <span class="text-xl shrink-0" aria-hidden="true">{d.icon}</span>
                <div>
                  <p class="text-xs font-oswald tracking-wider text-slate-500 uppercase mb-0.5">{d.label}</p>
                  <p class="font-mono font-bold text-green-400 text-sm">{d.date}</p>
                  <p class="text-slate-500 text-xs mt-0.5">{d.detalle}</p>
                </div>
              </div>
            ))}
          </div>

          <h3 class="font-oswald font-semibold text-white text-lg mb-2 mt-6">
            ¿Cuándo empieza el Mundial 2026?
          </h3>
          <p class="text-slate-400 leading-relaxed mb-4">
            El torneo comienza el <strong class="text-white">jueves 11 de junio de 2026</strong> a las 19:00 UTC (14:00 CDT en México y EE. UU. central) con el partido inaugural <strong class="text-white">México vs Ecuador</strong> en el Estadio Azteca de Ciudad de México, el templo del fútbol latinoamericano. Es la tercera vez en la historia que el Azteca acoge un Mundial.
          </p>

          <h3 class="font-oswald font-semibold text-white text-lg mb-2 mt-6">
            ¿Cuándo es la Final del Mundial 2026?
          </h3>
          <p class="text-slate-400 leading-relaxed">
            La <strong class="text-white">Gran Final del Mundial 2026</strong> se juega el <strong class="text-gold">domingo 19 de julio de 2026</strong> a las 22:00 UTC en el <strong class="text-white">MetLife Stadium</strong> (East Rutherford, Nueva Jersey), estadio más cercano a Manhattan y con capacidad para más de 82.000 espectadores. Consulta <a href="/horarios/mexico/ciudad-de-mexico" class="text-gold hover:underline">a qué hora es la final en tu ciudad</a>.
          </p>
        </section>

        <!-- ════════════════════════════════════════════════════
             2. DÓNDE SE JUEGA
        ════════════════════════════════════════════════════ -->
        <section id="donde" class="mb-12 scroll-mt-24">
          <h2 class="font-oswald font-bold text-white text-2xl sm:text-3xl mb-4 flex items-center gap-2">
            <span class="w-1 h-7 rounded" style="background:linear-gradient(180deg,#f5d97a,#d4af37);" aria-hidden="true"></span>
            ¿Dónde se Juega el Mundial 2026? Los 3 Países Sede
          </h2>
          <p class="text-slate-300 leading-relaxed mb-6">
            Por primera vez en la historia, el Mundial de Fútbol se celebra en <strong class="text-white">tres países simultáneamente</strong>: Estados Unidos, México y Canadá. La candidatura conjunta UNITED 2026 fue aprobada por FIFA en junio de 2018, superando a Marruecos.
          </p>

          <div class="space-y-4">
            <!-- USA -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl" aria-hidden="true">🇺🇸</span>
                <div>
                  <h3 class="font-oswald font-bold text-white text-xl">Estados Unidos — 11 sedes</h3>
                  <p class="text-slate-500 text-sm">El país anfitrión principal · 60 de los 104 partidos</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed mb-3">
                EE. UU. alberga la mayor parte del torneo con estadios en ambas costas y el sur. Los 11 estadios son todos recintos de la NFL adaptados para el fútbol, con aforos que oscilan entre 45.000 y 82.500 espectadores.
              </p>
              <div class="flex flex-wrap gap-2">
                {['Nueva York','Los Ángeles','Dallas','San Francisco','Seattle','Miami','Atlanta','Boston','Kansas City','Filadelfia','Houston'].map(c => (
                  <a href={`/sedes/${c.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'-').replace('á','a').replace('é','e').replace('ó','o')}`} class="bg-slate-800 hover:bg-gold/10 hover:text-gold text-slate-400 text-xs font-mono px-2.5 py-1 rounded-lg border border-slate-700 hover:border-gold/40 transition-all">
                    {c}
                  </a>
                ))}
              </div>
            </div>

            <!-- México -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl" aria-hidden="true">🇲🇽</span>
                <div>
                  <h3 class="font-oswald font-bold text-white text-xl">México — 3 sedes</h3>
                  <p class="text-slate-500 text-sm">Tercer Mundial en México · El Azteca hace historia por tercera vez</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed mb-3">
                México se convierte en el único país en albergar tres Mundiales (1970, 1986 y 2026). El Estadio Azteca de Ciudad de México es el único recinto en la historia que ha sido sede de dos finales mundialistas. Guadalajara (Estadio Akron) y Monterrey (Estadio BBVA) completan la terna mexicana.
              </p>
              <div class="flex flex-wrap gap-2">
                {[
                  { nombre: 'Ciudad de México', slug: 'ciudad-de-mexico' },
                  { nombre: 'Guadalajara',      slug: 'guadalajara'      },
                  { nombre: 'Monterrey',        slug: 'monterrey'        },
                ].map(c => (
                  <a href={`/sedes/${c.slug}`} class="bg-slate-800 hover:bg-gold/10 hover:text-gold text-slate-400 text-xs font-mono px-2.5 py-1 rounded-lg border border-slate-700 hover:border-gold/40 transition-all">
                    {c.nombre}
                  </a>
                ))}
              </div>
            </div>

            <!-- Canadá -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl" aria-hidden="true">🇨🇦</span>
                <div>
                  <h3 class="font-oswald font-bold text-white text-xl">Canadá — 2 sedes</h3>
                  <p class="text-slate-500 text-sm">Primer Mundial en Canadá · Toronto y Vancouver</p>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed mb-3">
                Canadá debuta como país sede de un Mundial con Toronto (BMO Field, 45.736 espectadores) y Vancouver (BC Place, con techo retráctil, 54.500 espectadores). Ambas ciudades acogerán partidos de Fase de Grupos.
              </p>
              <div class="flex flex-wrap gap-2">
                {[
                  { nombre: 'Toronto',   slug: 'toronto'   },
                  { nombre: 'Vancouver', slug: 'vancouver' },
                ].map(c => (
                  <a href={`/sedes/${c.slug}`} class="bg-slate-800 hover:bg-gold/10 hover:text-gold text-slate-400 text-xs font-mono px-2.5 py-1 rounded-lg border border-slate-700 hover:border-gold/40 transition-all">
                    {c.nombre}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>

        <AdSlot slot="3344556677" format="horizontal" label="Publicidad" />

        <!-- ════════════════════════════════════════════════════
             3. SEDES
        ════════════════════════════════════════════════════ -->
        <section id="sedes" class="mb-12 scroll-mt-24">
          <h2 class="font-oswald font-bold text-white text-2xl sm:text-3xl mb-4 flex items-center gap-2">
            <span class="w-1 h-7 rounded" style="background:linear-gradient(180deg,#f5d97a,#d4af37);" aria-hidden="true"></span>
            Sedes del Mundial 2026: Los 16 Estadios Oficiales
          </h2>
          <p class="text-slate-300 leading-relaxed mb-6">
            Los <strong class="text-white">16 estadios del Mundial 2026</strong> tienen una capacidad combinada de más de un millón de espectadores. Todos cumplen con los estándares FIFA para estadios de Categoría 1 (la más alta). A continuación, los más importantes:
          </p>

          <!-- Top sedes table -->
          <div class="overflow-x-auto rounded-2xl border border-slate-800 mb-6" style="background:#0a0f1e;">
            <table class="w-full text-sm border-collapse">
              <caption class="sr-only">Estadios del Mundial 2026 con capacidad y fase asignada</caption>
              <thead>
                <tr class="border-b border-slate-800">
                  <th scope="col" class="px-4 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase">Estadio</th>
                  <th scope="col" class="px-4 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase hidden sm:table-cell">Ciudad</th>
                  <th scope="col" class="px-4 py-3 text-right font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase">Aforo</th>
                  <th scope="col" class="px-4 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase hidden md:table-cell">Fase</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { estadio:'Estadio Azteca',        ciudad:'Ciudad de México', flag:'🇲🇽', aforo:'87,523', fase:'Cuartos de Final', slug:'ciudad-de-mexico', highlight: false },
                  { estadio:'MetLife Stadium',        ciudad:'Nueva York',       flag:'🇺🇸', aforo:'82,500', fase:'⭐ Gran Final',     slug:'nueva-york',       highlight: true  },
                  { estadio:'AT&T Stadium',           ciudad:'Dallas',           flag:'🇺🇸', aforo:'80,000', fase:'Octavos de Final', slug:'dallas',           highlight: false },
                  { estadio:'Arrowhead Stadium',      ciudad:'Kansas City',      flag:'🇺🇸', aforo:'76,416', fase:'Fase de Grupos',   slug:'kansas-city',      highlight: false },
                  { estadio:'Mercedes-Benz Stadium',  ciudad:'Atlanta',          flag:'🇺🇸', aforo:'71,000', fase:'Cuartos de Final', slug:'atlanta',          highlight: false },
                  { estadio:'NRG Stadium',            ciudad:'Houston',          flag:'🇺🇸', aforo:'72,220', fase:'Semifinal',        slug:'houston',          highlight: false },
                  { estadio:'SoFi Stadium',           ciudad:'Los Ángeles',      flag:'🇺🇸', aforo:'70,240', fase:'Semifinal',        slug:'los-angeles',      highlight: false },
                  { estadio:'Estadio BBVA',           ciudad:'Monterrey',        flag:'🇲🇽', aforo:'53,500', fase:'Fase de Grupos',   slug:'monterrey',        highlight: false },
                ].map((s, i) => (
                  <tr class={`border-b border-slate-800/60 transition-colors ${s.highlight ? 'bg-gold/5' : i%2===0 ? '' : 'bg-slate-900/40'} hover:bg-slate-800/40`}>
                    <td class="px-4 py-3">
                      <a href={`/sedes/${s.slug}`} class="text-white hover:text-gold font-semibold text-sm transition-colors">
                        {s.estadio}
                      </a>
                    </td>
                    <td class="px-4 py-3 font-mono text-slate-400 text-xs hidden sm:table-cell">
                      {s.flag} {s.ciudad}
                    </td>
                    <td class="px-4 py-3 text-right font-mono text-green-400 font-bold text-sm">{s.aforo}</td>
                    <td class="px-4 py-3 hidden md:table-cell">
                      <span class={`text-[10px] font-oswald tracking-wider px-2 py-0.5 rounded ${s.highlight ? 'bg-gold/20 text-gold' : 'bg-slate-800 text-slate-400'}`}>
                        {s.fase}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-slate-500 text-xs font-mono">
            → <a href="/sedes" class="text-gold hover:underline">Ver las 16 sedes completas con guía de transporte y hoteles</a>
          </p>
        </section>

        <!-- ════════════════════════════════════════════════════
             4. FORMATO
        ════════════════════════════════════════════════════ -->
        <section id="formato" class="mb-12 scroll-mt-24">
          <h2 class="font-oswald font-bold text-white text-2xl sm:text-3xl mb-4 flex items-center gap-2">
            <span class="w-1 h-7 rounded" style="background:linear-gradient(180deg,#f5d97a,#d4af37);" aria-hidden="true"></span>
            Formato del Mundial 2026: 48 Equipos y 12 Grupos
          </h2>
          <p class="text-slate-300 leading-relaxed mb-6">
            El Mundial 2026 estrena el <strong class="text-white">nuevo formato de 48 selecciones</strong>, ampliado desde los 32 equipos del torneo anterior. Esto supone <strong class="text-white">104 partidos</strong> en total, frente a los 64 del formato clásico.
          </p>

          <h3 class="font-oswald font-semibold text-white text-xl mb-3 mt-6">
            ¿Cuántos Equipos Participan en el Mundial 2026?
          </h3>
          <p class="text-slate-400 leading-relaxed mb-4">
            Participan <strong class="text-white">48 selecciones nacionales</strong> distribuidas en <strong class="text-white">12 grupos de 4 equipos</strong>. La distribución de plazas por confederación es:
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
            {[
              { conf:'UEFA (Europa)',   plazas:'16', flag:'🏆' },
              { conf:'CONMEBOL (S. Am.)',plazas:'6',  flag:'⚽' },
              { conf:'CAF (África)',    plazas:'9',  flag:'🌍' },
              { conf:'AFC (Asia)',      plazas:'8',  flag:'🌏' },
              { conf:'CONCACAF (N/C Am.)',plazas:'6', flag:'🌎' },
              { conf:'OFC (Oceanía)',   plazas:'1',  flag:'🏝️' },
            ].map(c => (
              <div class="bg-slate-900/60 border border-slate-800 rounded-xl p-3 text-center">
                <div class="text-xl mb-1" aria-hidden="true">{c.flag}</div>
                <div class="font-mono font-bold text-green-400 text-lg">{c.plazas}</div>
                <div class="text-slate-500 text-xs leading-tight mt-0.5">{c.conf}</div>
              </div>
            ))}
          </div>

