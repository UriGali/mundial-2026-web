---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import NearestMatches from '../components/NearestMatches.astro';

const title       = 'Mundial 2026 — Guía Completa | Sedes, Entradas y Equipos';
const description = 'Todo sobre el Mundial FIFA 2026: sedes en USA, México y Canadá, cómo comprar entradas, equipos clasificados, calendario y guía de viaje. ¡El torneo más grande de la historia!';
const keywords    = 'mundial 2026, copa del mundo 2026, world cup 2026, FIFA 2026, sedes mundial 2026, entradas mundial 2026, mundial usa mexico canada';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://mundial26horarios.com/#website',
      url: 'https://mundial26horarios.com/',
      name: 'Mundial 2026 — Guía para Fans',
      description,
      inLanguage: 'es',
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: 'https://mundial26horarios.com/buscar?q={search_term_string}' },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'SportsEvent',
      name: 'Copa Mundial de Fútbol FIFA 2026',
      alternateName: ['World Cup 2026', 'Mundial 2026'],
      startDate: '2026-06-11',
      endDate: '2026-07-19',
      eventStatus: 'https://schema.org/EventScheduled',
      location: { '@type': 'Place', name: 'Estados Unidos, México y Canadá' },
      organizer: { '@type': 'Organization', name: 'FIFA', url: 'https://www.fifa.com' },
      description: 'El torneo de fútbol más grande de la historia. 48 selecciones, 16 sedes y 3 países anfitriones del 11 de junio al 19 de julio de 2026.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: '¿Cuándo empieza el Mundial 2026?', acceptedAnswer: { '@type': 'Answer', text: 'El Mundial FIFA 2026 empieza el 11 de junio de 2026 y termina el 19 de julio con la Gran Final en MetLife Stadium, Nueva York.' } },
        { '@type': 'Question', name: '¿Cuántos equipos participan en el Mundial 2026?', acceptedAnswer: { '@type': 'Answer', text: '48 selecciones nacionales participan en el Mundial 2026, divididas en 12 grupos de 4 equipos.' } },
        { '@type': 'Question', name: '¿Dónde se juega la Final del Mundial 2026?', acceptedAnswer: { '@type': 'Answer', text: 'La Final del Mundial 2026 es el 19 de julio de 2026 en MetLife Stadium, East Rutherford, Nueva Jersey (área metropolitana de Nueva York).' } },
        { '@type': 'Question', name: '¿En qué países se juega el Mundial 2026?', acceptedAnswer: { '@type': 'Answer', text: 'En tres países: Estados Unidos (11 sedes), México (3: Ciudad de México, Guadalajara, Monterrey) y Canadá (2: Toronto, Vancouver).' } },
        { '@type': 'Question', name: '¿Cómo comprar entradas para el Mundial 2026?', acceptedAnswer: { '@type': 'Answer', text: 'Solo a través del portal oficial de FIFA. Pasos: 1) Crea tu ID en FIFA.com, 2) Selecciona partidos, 3) Paga y confirma. Las entradas son nominales.' } },
        { '@type': 'Question', name: '¿Cuántos partidos se juegan en el Mundial 2026?', acceptedAnswer: { '@type': 'Answer', text: '104 partidos: 72 en Fase de Grupos + 32 en eliminatorias (Octavos, Cuartos, Semis, 3.er puesto y Final).' } },
      ],
    },
  ],
};

// Bento grid: 10 sedes clave con datos visuales
const bentoSedes = [
  {
    slug: 'ciudad-de-mexico', ciudad: 'Ciudad de México', estadio: 'Estadio Azteca',
    fase: 'Cuartos · Final', faseClass: 'bg-orange-500', flag: '🇲🇽', capacidad: '87,523',
    tag: 'SEDE HISTÓRICA',
    gradient: 'linear-gradient(160deg,#0a2200 0%,#1a4f00 50%,#2d6600 100%)',
    img: 'https://picsum.photos/seed/azteca-cdmx-wc/1200/800',
    size: 'feature',
  },
  {
    slug: 'nueva-york', ciudad: 'Nueva York', estadio: 'MetLife Stadium',
    fase: '⭐ GRAN FINAL', faseClass: 'bg-gold text-slate-950', flag: '🇺🇸', capacidad: '82,500',
    tag: 'GRAN FINAL',
    gradient: 'linear-gradient(160deg,#010314 0%,#060d1f 50%,#0f1a3e 100%)',
    img: 'https://picsum.photos/seed/metlife-ny-wc/1200/700',
    size: 'tall',
  },
  {
    slug: 'houston', ciudad: 'Houston', estadio: 'NRG Stadium',
    fase: 'Semifinal', faseClass: 'bg-purple-600', flag: '🇺🇸', capacidad: '72,220',
    tag: 'SEMIFINAL',
    gradient: 'linear-gradient(160deg,#130a20 0%,#200d35 50%,#2e0f4a 100%)',
    img: 'https://picsum.photos/seed/nrg-houston-wc/1200/700',
    size: 'tall',
  },
  {
    slug: 'los-angeles', ciudad: 'Los Ángeles', estadio: 'SoFi Stadium',
    fase: 'Semifinal', faseClass: 'bg-blue-600', flag: '🇺🇸', capacidad: '70,240',
    tag: 'SEMIFINAL',
    gradient: 'linear-gradient(160deg,#000d2e 0%,#001a56 50%,#002b85 100%)',
    img: 'https://picsum.photos/seed/sofi-la-wc/1200/600',
    size: 'medium',
  },
  {
    slug: 'dallas', ciudad: 'Dallas', estadio: "AT&T Stadium",
    fase: 'Cuartos', faseClass: 'bg-sky-600', flag: '🇺🇸', capacidad: '80,000',
    tag: 'CUARTOS',
    gradient: 'linear-gradient(160deg,#050510 0%,#0a0a20 50%,#101030 100%)',
    img: 'https://picsum.photos/seed/att-dallas-wc/1200/600',
    size: 'medium',
  },
  {
    slug: 'atlanta', ciudad: 'Atlanta', estadio: 'Mercedes-Benz Stadium',
    fase: 'Cuartos', faseClass: 'bg-orange-600', flag: '🇺🇸', capacidad: '71,000',
    tag: 'CUARTOS',
    gradient: 'linear-gradient(160deg,#0a0a14 0%,#1a0a20 50%,#2a0a30 100%)',
    img: 'https://picsum.photos/seed/mb-atlanta-wc/1200/600',
    size: 'medium',
  },
  {
    slug: 'guadalajara', ciudad: 'Guadalajara', estadio: 'Estadio Akron',
    fase: 'Fase de Grupos', faseClass: 'bg-blue-700', flag: '🇲🇽', capacidad: '49,850',
    tag: 'SEDE MEXICO',
    gradient: 'linear-gradient(160deg,#001a30 0%,#002545 50%,#003060 100%)',
    img: 'https://picsum.photos/seed/akron-gdl-wc/1200/500',
    size: 'small',
  },
  {
    slug: 'miami', ciudad: 'Miami', estadio: 'Hard Rock Stadium',
    fase: 'Octavos', faseClass: 'bg-teal-600', flag: '🇺🇸', capacidad: '64,767',
    tag: 'OCTAVOS',
    gradient: 'linear-gradient(160deg,#001a2e 0%,#002d4a 50%,#004466 100%)',
    img: 'https://picsum.photos/seed/hardrock-miami-wc/1200/500',
    size: 'small',
  },
  {
    slug: 'seattle', ciudad: 'Seattle', estadio: 'Lumen Field',
    fase: 'Octavos', faseClass: 'bg-teal-700', flag: '🇺🇸', capacidad: '69,000',
    tag: 'OCTAVOS',
    gradient: 'linear-gradient(160deg,#001a10 0%,#002a18 50%,#003a20 100%)',
    img: 'https://picsum.photos/seed/lumen-seattle-wc/1200/500',
    size: 'small',
  },
  {
    slug: 'vancouver', ciudad: 'Vancouver', estadio: 'BC Place',
    fase: 'Octavos', faseClass: 'bg-red-700', flag: '🇨🇦', capacidad: '54,500',
    tag: 'SEDE CANADÁ',
    gradient: 'linear-gradient(160deg,#001020 0%,#001a30 50%,#002a40 100%)',
    img: 'https://picsum.photos/seed/bcplace-vancouver-wc/1200/500',
    size: 'small',
  },
];

const categorias = [
  { num: '1', nombre: 'Categoría Premium', desc: 'Mejor visibilidad, asientos centrales, zonas VIP', precio: 'Desde $210 USD', color: 'gold' },
  { num: '2', nombre: 'Categoría Estándar', desc: 'Excelente vista. La mejor relación calidad-precio', precio: 'Desde $105 USD', color: 'blue' },
  { num: '3', nombre: 'Categoría General', desc: 'Acceso general. El mejor ambiente de la tribuna', precio: 'Desde $70 USD', color: 'slate' },
  { num: '4', nombre: 'Categoría Residentes', desc: 'Solo para residentes acreditados del país sede', precio: 'Desde $35 USD', color: 'green' },
];
---

<Layout {title} {description} {keywords} {jsonLd}>

  <!-- ===================================================
       HERO — Premium magazine style
  ==================================================== -->
  <section
    class="relative overflow-hidden min-h-screen flex flex-col justify-center items-center text-white text-center px-4 py-24"
    aria-labelledby="hero-heading"
    style="background: linear-gradient(160deg,#020617 0%,#0f172a 45%,#1e293b 75%,#020617 100%);"
  >
    <!-- Textura de puntos dorados -->
    <div
      class="absolute inset-0 opacity-100 pointer-events-none"
      style="background-image: radial-gradient(rgba(212,175,55,0.08) 1px, transparent 1px); background-size: 28px 28px;"
      aria-hidden="true"
    ></div>

    <!-- Líneas de grid sutiles -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(rgba(212,175,55,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(212,175,55,0.03) 1px, transparent 1px); background-size: 80px 80px;"
      aria-hidden="true"
    ></div>

    <!-- Resplandor central -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full pointer-events-none"
      style="background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Número fantasma 2026 de fondo -->
    <div
      class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden"
      aria-hidden="true"
    >
      <span
        class="font-oswald font-bold leading-none text-white/[0.03]"
        style="font-size: clamp(10rem, 30vw, 28rem); letter-spacing: -0.02em;"
      >2026</span>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto">

      <!-- Badge urgencia -->
      <div class="inline-flex items-center gap-2.5 border rounded-full px-5 py-2 text-xs font-medium tracking-widest uppercase mb-8"
        style="background: rgba(212,175,55,0.08); border-color: rgba(212,175,55,0.3); color: #d4af37;">
        <span class="w-2 h-2 rounded-full animate-pulse" style="background-color: #d4af37;" aria-hidden="true"></span>
        Copa Mundial FIFA 2026 &mdash; 11 Jun &ndash; 19 Jul
      </div>

      <!-- Headline principal con Oswald -->
      <h1
        id="hero-heading"
        class="font-oswald font-bold leading-[0.9] tracking-tight mb-6"
        style="font-size: clamp(3.5rem, 10vw, 8.5rem);"
      >
        <span class="block text-white">COPA</span>
        <span class="block text-white">MUNDIAL</span>
        <span
          class="block bg-clip-text text-transparent"
          style="background-image: linear-gradient(105deg,#b8922a 0%,#d4af37 30%,#f5d97a 50%,#d4af37 70%,#b8922a 100%);"
        >FIFA 2026</span>
      </h1>

      <!-- Países -->
      <p class="font-oswald text-xl sm:text-2xl text-slate-400 tracking-[0.15em] uppercase mb-10">
        🇺🇸 <span class="text-slate-300">USA</span>
        <span class="text-slate-600 mx-3">·</span>
        🇲🇽 <span class="text-slate-300">México</span>
        <span class="text-slate-600 mx-3">·</span>
        🇨🇦 <span class="text-slate-300">Canadá</span>
      </p>

      <!-- Countdown — glass morphism -->
      <div
        id="countdown-wrapper"
        class="flex justify-center gap-3 sm:gap-4 mb-10"
        aria-live="polite"
        aria-label="Cuenta regresiva para el Mundial"
      >
        {['cd-days','cd-hours','cd-minutes','cd-seconds'].map((id, i) => (
          <div
            class="flex flex-col items-center rounded-2xl px-4 sm:px-6 py-4 border min-w-[68px] sm:min-w-[84px]"
            style="background: rgba(255,255,255,0.04); backdrop-filter: blur(12px); border-color: rgba(212,175,55,0.2);"
          >
            <span id={id} class="font-oswald font-bold text-3xl sm:text-5xl tabular-nums"
              style="background-image: linear-gradient(180deg,#f5d97a,#d4af37); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
              --
            </span>
            <span class="text-[10px] sm:text-xs text-slate-500 uppercase tracking-[0.15em] mt-1 font-medium">
              {['Días','Horas','Min','Seg'][i]}
            </span>
          </div>
        ))}
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-14">
        <a
          href="#sedes"
          class="font-oswald font-semibold tracking-wider text-sm px-8 py-3.5 rounded-full text-slate-950 transition-all duration-200 hover:scale-105 hover:shadow-gold uppercase"
          style="background-image: linear-gradient(105deg,#b8922a 0%,#d4af37 40%,#f5d97a 60%,#d4af37 80%,#b8922a 100%);"
        >
          Ver las 16 Sedes
        </a>
        <a
          href="/entradas"
          class="font-oswald font-semibold tracking-wider text-sm px-8 py-3.5 rounded-full text-white transition-all duration-200 hover:scale-105 uppercase border"
          style="border-color: rgba(212,175,55,0.4); background: rgba(212,175,55,0.05);"
          onmouseover="this.style.background='rgba(212,175,55,0.1)'"
          onmouseout="this.style.background='rgba(212,175,55,0.05)'"
        >
          Comprar Entradas
        </a>
      </div>

      <!-- Stats — glass chips -->
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        {[
          { num: '48', label: 'Selecciones' },
          { num: '16', label: 'Ciudades' },
          { num: '3',  label: 'Países' },
          { num: '104',label: 'Partidos' },
        ].map(({ num, label }) => (
          <div
            class="flex items-center gap-2 rounded-full px-5 py-2 border"
            style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);"
          >
            <span class="font-oswald font-bold text-base" style="color: #d4af37;">{num}</span>
            <span class="text-slate-400 font-medium">{label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <a
      href="#sedes"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 text-slate-600 hover:text-gold transition-colors animate-bounce"
      aria-label="Ver sedes"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <!-- ===================================================
       BANNER DE DATOS RÁPIDOS
  ==================================================== -->
  <section
    class="border-y py-5"
    style="background: rgba(212,175,55,0.04); border-color: rgba(212,175,55,0.12);"
    aria-label="Datos clave del Mundial 2026"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { icon: '🏟️', text: 'El mundial más grande de la historia' },
          { icon: '📅', text: '11 junio — 19 julio 2026' },
          { icon: '🌎', text: 'Primera vez en 3 naciones a la vez' },
          { icon: '🏆', text: '48 selecciones clasificadas' },
        ].map(({ icon, text }) => (
          <div class="flex flex-col items-center gap-1.5">
            <span class="text-2xl" aria-hidden="true">{icon}</span>
            <p class="text-xs sm:text-sm text-slate-400 font-medium">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ad: Leaderboard -->
  <AdSlot slot="1234567890" format="horizontal" label="Publicidad" />

  <!-- ===================================================
       BENTO GRID — SEDES
  ==================================================== -->
  <section
    id="sedes"
    class="py-20 px-4 sm:px-6 lg:px-8"
    style="background: #020617;"
    aria-labelledby="sedes-heading"
  >
    <div class="max-w-7xl mx-auto">

      <!-- Encabezado sección -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
        <div>
          <p class="font-oswald text-xs uppercase tracking-[0.2em] mb-2" style="color: #d4af37;">
            16 ciudades · 3 países
          </p>
          <h2 id="sedes-heading" class="font-oswald font-bold text-4xl sm:text-5xl text-white leading-tight">
            Las Sedes del<br/>
            <span
              class="bg-clip-text text-transparent"
              style="background-image: linear-gradient(105deg,#b8922a,#d4af37,#f5d97a,#d4af37,#b8922a);"
            >Mundial 2026</span>
          </h2>
        </div>
        <a
          href="/sedes"
          class="shrink-0 font-oswald font-semibold text-sm uppercase tracking-wider px-6 py-2.5 rounded-full border transition-all hover:scale-105"
          style="border-color: rgba(212,175,55,0.4); color: #d4af37; background: rgba(212,175,55,0.05);"
        >
          Ver las 16 →
        </a>
      </div>

      <!-- Bento Grid asimétrico -->
      <div class="grid gap-3">

        <!-- Fila 1: Feature (3/5) + 2 stacked (2/5) -->
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-3">

          <!-- CDMX — Feature Card grande -->
          <a
            href="/sedes/ciudad-de-mexico"
            class="lg:col-span-3 relative overflow-hidden rounded-2xl group cursor-pointer block"
            style="height: 460px; background: linear-gradient(160deg,#0a2200 0%,#1a4f00 50%,#2d6600 100%);"
            aria-label="Ciudad de México — Sede del Mundial 2026"
          >
            <img
              src="https://picsum.photos/seed/azteca-cdmx-wc/1200/800"
              alt="Ciudad de México"
              class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Overlay -->
            <div class="absolute inset-0 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(2,6,23,0.95) 0%, rgba(2,6,23,0.5) 50%, rgba(2,6,23,0.1) 100%);"></div>
            <!-- Gold glow hover -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 100%, rgba(212,175,55,0.1) 0%, transparent 70%);"></div>
            <!-- Gold border hover -->
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10 group-hover:ring-gold/40 transition-all duration-300"></div>
            <!-- Tag -->
            <div class="absolute top-4 left-4 z-10">
              <span class="font-oswald font-semibold text-[10px] tracking-[0.2em] uppercase px-3 py-1.5 rounded-full text-slate-950"
                style="background-image: linear-gradient(105deg,#b8922a,#d4af37,#f5d97a,#d4af37,#b8922a);">
                SEDE HISTÓRICA
              </span>
            </div>
            <!-- Content -->
            <div class="absolute bottom-0 left-0 right-0 z-10 p-7">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-oswald text-xs uppercase tracking-[0.15em] px-2.5 py-1 rounded-full bg-orange-500/80 text-white">Cuartos de Final</span>
              </div>
              <p class="text-slate-400 text-sm font-medium mb-1">🇲🇽 México</p>
              <h3 class="font-oswald font-bold text-4xl sm:text-5xl text-white leading-tight mb-2">Ciudad de México</h3>
              <p class="text-slate-400 text-sm mb-3">Estadio Azteca</p>
              <div class="flex items-center gap-4">
                <span class="font-oswald font-bold text-lg" style="color: #d4af37;">87,523</span>
                <span class="text-slate-500 text-xs uppercase tracking-wider">espectadores</span>
              </div>
            </div>
          </a>

          <!-- Columna derecha: NY + Houston apilados -->
          <div class="lg:col-span-2 grid grid-rows-2 gap-3" style="height: 460px;">

            <!-- NY Final -->
            <a
              href="/sedes/nueva-york"
              class="relative overflow-hidden rounded-2xl group cursor-pointer block"
              style="background: linear-gradient(160deg,#010314 0%,#060d1f 50%,#0f1a3e 100%);"
              aria-label="Nueva York — Gran Final del Mundial 2026"
            >
              <img
                src="https://picsum.photos/seed/metlife-ny-wc/1200/700"
                alt="Nueva York"
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(2,6,23,0.95) 0%, rgba(2,6,23,0.4) 60%, transparent 100%);"></div>
              <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10 group-hover:ring-gold/40 transition-all duration-300"></div>
              <div class="absolute top-3 left-3 z-10">
                <span class="font-oswald font-semibold text-[10px] tracking-widest uppercase px-3 py-1.5 rounded-full text-slate-950"
                  style="background-image: linear-gradient(105deg,#b8922a,#d4af37,#f5d97a,#d4af37,#b8922a);">
                  ⭐ GRAN FINAL
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 z-10 p-5">
                <p class="text-slate-400 text-xs mb-0.5">🇺🇸 Nueva York / NJ</p>
                <h3 class="font-oswald font-bold text-2xl text-white">MetLife Stadium</h3>
                <p class="text-sm font-bold mt-1" style="color: #d4af37;">82,500 espectadores</p>
              </div>
            </a>

            <!-- Houston Semifinal -->
            <a
              href="/sedes/houston"
              class="relative overflow-hidden rounded-2xl group cursor-pointer block"
              style="background: linear-gradient(160deg,#130a20 0%,#200d35 50%,#2e0f4a 100%);"
              aria-label="Houston — Semifinal del Mundial 2026"
            >
              <img
                src="https://picsum.photos/seed/nrg-houston-wc/1200/700"
                alt="Houston"
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(2,6,23,0.95) 0%, rgba(2,6,23,0.4) 60%, transparent 100%);"></div>
              <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10 group-hover:ring-gold/40 transition-all duration-300"></div>
              <div class="absolute top-3 left-3 z-10">
                <span class="font-oswald font-semibold text-[10px] tracking-widest uppercase px-2.5 py-1 rounded-full bg-purple-600/80 text-white">Semifinal</span>
