interface Props { article: Article; }
const { article } = Astro.props;
const { title, description, keywords, date, dateLabel, category, categoryColor, img, readTime, sections } = article;

const canonicalURL = `https://mundial26horarios.com/noticias/${article.slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',   item: 'https://mundial26horarios.com/' },
        { '@type': 'ListItem', position: 2, name: 'Noticias', item: 'https://mundial26horarios.com/noticias' },
        { '@type': 'ListItem', position: 3, name: title,      item: canonicalURL },
      ],
    },
    {
      '@type': 'NewsArticle',
      headline: title,
      description,
      datePublished: date,
      dateModified: date,
      url: canonicalURL,
      image: img,
      author: { '@type': 'Organization', name: 'Mundial 2026 Guía', url: 'https://mundial26horarios.com' },
      publisher: { '@type': 'Organization', name: 'Mundial 2026 Guía', url: 'https://mundial26horarios.com' },
      inLanguage: 'es',
      about: { '@type': 'SportsEvent', name: 'Copa Mundial de Fútbol FIFA 2026' },
    },
  ],
};

// Los otros dos artículos (para sección "Sigue leyendo")
const otherArticles = articles.filter(a => a.slug !== article.slug);
---

<Layout {title} {description} {keywords} canonicalURL={canonicalURL} jsonLd={jsonLd}>

  <!-- Hero del artículo -->
  <div class="relative h-64 sm:h-80 overflow-hidden" aria-hidden="true">
    <img
      src={img}
      alt={title}
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(2,6,23,0.3) 0%, rgba(2,6,23,0.85) 100%);"></div>
  </div>

  <!-- Contenido principal -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 relative z-10 pb-20">

    <!-- Card del artículo -->
    <article
      class="rounded-2xl overflow-hidden border border-white/10"
      style="background: #0f172a;"
      itemscope itemtype="https://schema.org/NewsArticle"
    >

      <!-- Cabecera -->
      <header class="px-6 sm:px-10 pt-8 pb-6 border-b border-white/10">

        <!-- Breadcrumb + meta -->
        <div class="flex flex-wrap items-center gap-3 mb-5 text-xs">
          <a href="/" class="text-slate-500 hover:text-gold transition-colors">Inicio</a>
          <span class="text-slate-700" aria-hidden="true">/</span>
          <a href="/noticias" class="text-slate-500 hover:text-gold transition-colors">Noticias</a>
          <span class="text-slate-700" aria-hidden="true">/</span>
          <span class="text-slate-400 line-clamp-1">{title}</span>
        </div>

        <!-- Badges -->
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class={`text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-white ${categoryColor}`}>
            {category}
          </span>
          <time datetime={date} class="text-xs text-slate-500 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {dateLabel}
          </time>
          <span class="text-xs text-slate-500 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {readTime} lectura
          </span>
        </div>

        <h1 class="font-oswald font-bold text-2xl sm:text-3xl lg:text-4xl text-white leading-tight" itemprop="headline">
          {title}
        </h1>
      </header>

      <!-- Cuerpo del artículo -->
      <div class="px-6 sm:px-10 py-8 prose-article">

        {sections.map((section, i) => (
          <div>
            {section.type === 'text' && (
              <p class="text-slate-300 text-base sm:text-lg leading-relaxed mb-6">{section.text}</p>
            )}

            {section.type === 'h2' && (
              <div class="mb-6">
                <h2 class="font-oswald font-bold text-xl sm:text-2xl text-white mt-10 mb-3 flex items-center gap-2">
                  <span class="w-1 h-6 rounded-full shrink-0" style="background: #d4af37;" aria-hidden="true"></span>
                  {section.heading}
                </h2>
                {section.text && <p class="text-slate-300 text-base leading-relaxed">{section.text}</p>}
              </div>
            )}

            {section.type === 'list' && (
              <div class="mb-6">
                {section.heading && (
                  <h2 class="font-oswald font-bold text-xl sm:text-2xl text-white mt-10 mb-4 flex items-center gap-2">
                    <span class="w-1 h-6 rounded-full shrink-0" style="background: #d4af37;" aria-hidden="true"></span>
                    {section.heading}
                  </h2>
                )}
                <ul class="space-y-2.5">
                  {section.items?.map(item => (
                    <li class="flex items-start gap-3 text-slate-300 text-sm sm:text-base">
                      <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background: #d4af37;" aria-hidden="true"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {section.type === 'tip' && (
              <div class="my-8 rounded-xl p-5 border" style="background: rgba(212,175,55,0.06); border-color: rgba(212,175,55,0.25);">
                <p class="font-oswald font-bold text-sm uppercase tracking-wider mb-2" style="color: #d4af37;">
                  Consejo
                  {section.heading && ` — ${section.heading}`}
                </p>
                <p class="text-slate-300 text-sm leading-relaxed">{section.text}</p>
              </div>
            )}

            {section.type === 'warning' && (
              <div class="my-8 rounded-xl p-5 border border-red-500/30" style="background: rgba(239,68,68,0.06);">
                <p class="font-oswald font-bold text-sm uppercase tracking-wider mb-2 text-red-400">
                  Advertencia
                  {section.heading && ` — ${section.heading}`}
                </p>
                <p class="text-slate-300 text-sm leading-relaxed">{section.text}</p>
              </div>
            )}

            {/* Ad entre secciones (aprox mitad del artículo) */}
            {i === Math.floor(sections.length / 2) - 1 && (
              <AdSlot slot="7788990011" format="horizontal" label="Publicidad" />
            )}
          </div>
        ))}

      </div>

      <!-- Footer del artículo -->
      <footer class="px-6 sm:px-10 pb-8 pt-4 border-t border-white/10">
        <div class="flex flex-wrap gap-4 items-center justify-between">
          <a
            href="/noticias"
            class="inline-flex items-center gap-2 text-sm font-medium hover:text-gold transition-colors"
            style="color: #d4af37;"
          >
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            Todas las noticias
          </a>
          <a
            href="/calendario"
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-white transition-colors"
          >
            Ver calendario de partidos
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </footer>
    </article>

    <!-- Ad final -->
    <AdSlot slot="8899001122" format="rectangle" label="Publicidad" class="mt-8" />

    <!-- Sigue leyendo -->
    <section class="mt-12" aria-labelledby="sigue-leyendo">
      <h2 id="sigue-leyendo" class="font-oswald font-bold text-2xl text-white mb-6 flex items-center gap-2">
        <span class="w-1 h-6 rounded-full" style="background: #d4af37;" aria-hidden="true"></span>
        Sigue leyendo
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {otherArticles.map(a => (
          <a
            href={`/noticias/${a.slug}`}
            class="group rounded-xl overflow-hidden border border-white/10 hover:border-gold/30 transition-all duration-300 hover:-translate-y-0.5"
            style="background: #0f172a;"
          >
            <div class="relative h-36 overflow-hidden">
              <img src={a.img} alt={a.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 40%, rgba(15,23,42,0.9) 100%);"></div>
              <span class={`absolute top-3 left-3 text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full text-white ${a.categoryColor}`}>
                {a.category}
              </span>
            </div>
            <div class="p-4">
              <p class="text-sm font-semibold text-slate-200 group-hover:text-white transition-colors leading-snug line-clamp-2">{a.title}</p>
              <p class="text-xs text-slate-500 mt-1.5">{a.dateLabel} · {a.readTime} lectura</p>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>

</Layout>
