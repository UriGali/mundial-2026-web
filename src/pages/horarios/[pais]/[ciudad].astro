  { slug: 'seattle',          ciudad: 'Seattle',           pais: 'EE. UU.', flag: '🇺🇸', estadio: 'Lumen Field'             },
  { slug: 'kansas-city',      ciudad: 'Kansas City',       pais: 'EE. UU.', flag: '🇺🇸', estadio: 'Arrowhead Stadium'       },
  { slug: 'boston',           ciudad: 'Boston',            pais: 'EE. UU.', flag: '🇺🇸', estadio: 'Gillette Stadium'        },
  { slug: 'miami',            ciudad: 'Miami',             pais: 'EE. UU.', flag: '🇺🇸', estadio: 'Hard Rock Stadium'       },
  { slug: 'atlanta',          ciudad: 'Atlanta',           pais: 'EE. UU.', flag: '🇺🇸', estadio: 'Mercedes-Benz Stadium'   },
  { slug: 'houston',          ciudad: 'Houston',           pais: 'EE. UU.', flag: '🇺🇸', estadio: 'NRG Stadium'             },
  { slug: 'filadelfia',       ciudad: 'Filadelfia',        pais: 'EE. UU.', flag: '🇺🇸', estadio: 'Lincoln Financial Field' },
  { slug: 'vancouver',        ciudad: 'Vancouver',         pais: 'Canadá',  flag: '🇨🇦', estadio: 'BC Place'                },
  { slug: 'toronto',          ciudad: 'Toronto',           pais: 'Canadá',  flag: '🇨🇦', estadio: 'BMO Field'               },
];

const todasLasCiudadesHorarios = [
  { pais: 'mexico',    ciudad: 'ciudad-de-mexico', nombre: 'Ciudad de México', paisNombre: 'México',    flag: '🇲🇽' },
  { pais: 'mexico',    ciudad: 'guadalajara',      nombre: 'Guadalajara',      paisNombre: 'México',    flag: '🇲🇽' },
  { pais: 'mexico',    ciudad: 'monterrey',        nombre: 'Monterrey',        paisNombre: 'México',    flag: '🇲🇽' },
  { pais: 'espana',    ciudad: 'madrid',           nombre: 'Madrid',           paisNombre: 'España',    flag: '🇪🇸' },
  { pais: 'espana',    ciudad: 'barcelona',        nombre: 'Barcelona',        paisNombre: 'España',    flag: '🇪🇸' },
  { pais: 'espana',    ciudad: 'sevilla',          nombre: 'Sevilla',          paisNombre: 'España',    flag: '🇪🇸' },
  { pais: 'argentina', ciudad: 'buenos-aires',     nombre: 'Buenos Aires',     paisNombre: 'Argentina', flag: '🇦🇷' },
  { pais: 'argentina', ciudad: 'cordoba',          nombre: 'Córdoba',          paisNombre: 'Argentina', flag: '🇦🇷' },
  { pais: 'usa',       ciudad: 'nueva-york',       nombre: 'Nueva York',       paisNombre: 'EE. UU.',   flag: '🇺🇸' },
  { pais: 'usa',       ciudad: 'los-angeles',      nombre: 'Los Ángeles',      paisNombre: 'EE. UU.',   flag: '🇺🇸' },
  { pais: 'usa',       ciudad: 'chicago',          nombre: 'Chicago',          paisNombre: 'EE. UU.',   flag: '🇺🇸' },
  { pais: 'colombia',  ciudad: 'bogota',           nombre: 'Bogotá',           paisNombre: 'Colombia',  flag: '🇨🇴' },
  { pais: 'colombia',  ciudad: 'medellin',         nombre: 'Medellín',         paisNombre: 'Colombia',  flag: '🇨🇴' },
];

// ── SEO metadata ───────────────────────────────────────────────────────────────
const title       = `Horarios Mundial 2026 en ${ciudad.nombre}, ${pais.nombre} — Hora Local (${ciudad.offsetLabel})`;
const description = `¿A qué hora son los partidos del Mundial 2026 en ${ciudad.nombre}? Tabla completa con los horarios convertidos a ${ciudad.abbr} (${ciudad.offsetLabel}). Fase de Grupos y Fases Eliminatorias con horario local exacto.`;
const canonicalURL = `https://mundial26horarios.com/horarios/${pais.slug}/${ciudad.slug}`;

// ── JSON-LD ────────────────────────────────────────────────────────────────────
const finalConv   = horaLocal('2026-07-19', '22:00', tz, loc);
const estelarConv = horaLocal('2026-06-11', '22:00', tz, loc);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',   item: 'https://mundial26horarios.com/' },
        { '@type': 'ListItem', position: 2, name: 'Horarios', item: 'https://mundial26horarios.com/horarios' },
        { '@type': 'ListItem', position: 3, name: pais.nombre, item: `https://mundial26horarios.com/horarios/${pais.slug}` },
        { '@type': 'ListItem', position: 4, name: ciudad.nombre, item: canonicalURL },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: `¿A qué hora es la final del Mundial 2026 en ${ciudad.nombre}?`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `La final del Mundial 2026 se juega el domingo 19 de julio de 2026 a las ${finalConv.hora} ${ciudad.abbr} (22:00 UTC) en el MetLife Stadium de Nueva York, EE. UU.`,
          },
        },
        {
          '@type': 'Question',
          name: `¿En qué horario se ven los partidos nocturnos del Mundial desde ${ciudad.nombre}?`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Los partidos estelares (22:00 UTC) se transmiten a las ${estelarConv.hora} ${ciudad.abbr} en ${ciudad.nombre}. ${ciudad.nombre} opera en ${ciudad.offsetLabel} durante el verano boreal (junio–julio 2026).`,
          },
        },
        {
          '@type': 'Question',
          name: `¿Cuántas horas de diferencia hay entre UTC y ${ciudad.nombre} durante el Mundial 2026?`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Durante el Mundial 2026 (junio–julio 2026), ${ciudad.nombre} opera en ${ciudad.abbr} (${ciudad.offsetLabel} respecto a UTC). Para convertir: hora UTC ${ciudad.offsetLabel.startsWith('UTC+') ? '+' : ''}${ciudad.offsetLabel.replace('UTC', '').replace('−', '-')} horas = hora local en ${ciudad.nombre}.`,
          },
        },
      ],
    },
  ],
};
---

<Layout {title} {description} {canonicalURL} {jsonLd}>

  <!-- ═══════════════════════════════════════════════════
       HERO — Airport dark theme
  ════════════════════════════════════════════════════ -->
  <section
    class="relative text-white py-14 sm:py-20 px-4 overflow-hidden"
    style="background: linear-gradient(160deg, #020617 0%, #0a1628 50%, #020617 100%);"
    aria-labelledby="page-heading"
  >
    <!-- Grid overlay -->
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style="background-image: linear-gradient(rgba(212,175,55,0.8) 1px,transparent 1px),linear-gradient(90deg,rgba(212,175,55,0.8) 1px,transparent 1px); background-size: 40px 40px;"
      aria-hidden="true"
    ></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-slate-600 flex justify-center" aria-label="Migas de pan">
        <ol class="flex items-center gap-1.5 flex-wrap justify-center font-mono text-xs">
          <li><a href="/" class="hover:text-gold transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-700">/</li>
          <li><a href="/horarios" class="hover:text-gold transition-colors">Horarios</a></li>
          <li aria-hidden="true" class="text-slate-700">/</li>
          <li><a href={`/horarios/${pais.slug}`} class="hover:text-gold transition-colors">{pais.nombre}</a></li>
          <li aria-hidden="true" class="text-slate-700">/</li>
          <li class="text-slate-400" aria-current="page">{ciudad.nombre}</li>
        </ol>
      </nav>

      <span class="text-5xl mb-3 block" role="img" aria-label={pais.nombre}>{pais.flag}</span>

      <h1 id="page-heading" class="font-oswald font-bold leading-tight mb-3" style="font-size: clamp(2rem, 6vw, 3.5rem);">
        Horarios del Mundial 2026<br class="hidden sm:block" />
        <span
          class="bg-clip-text text-transparent"
          style="background-image: linear-gradient(105deg,#b8922a 0%,#d4af37 40%,#f5d97a 60%,#d4af37 80%,#b8922a 100%);"
        > en {ciudad.nombre}</span>
      </h1>

      <p class="text-slate-400 text-base sm:text-lg mb-8 font-mono">
        {pais.nombre} · Zona horaria: <strong class="text-white">{ciudad.abbr} ({ciudad.offsetLabel})</strong>
      </p>

      <!-- UTC conversion chips — dark glass -->
      <div class="flex flex-wrap justify-center gap-3">
        {refTable.map(r => (
          <div
            class="border border-slate-700/60 rounded-xl px-4 py-2.5 text-center min-w-[100px]"
            style="background: rgba(255,255,255,0.04); backdrop-filter: blur(8px);"
          >
            <p class="text-xs text-slate-500 font-mono mb-0.5">{r.horaUTC} UTC</p>
            <p class="font-mono font-bold text-green-400 text-lg leading-none">{r.local}</p>
            <p class="text-xs text-slate-600 mt-0.5">{r.etiqueta}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       MAIN CONTENT
  ════════════════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Tu hora local — client-side trust signal -->
    <div
      id="tz-banner"
      class="hidden items-center gap-3 bg-green-950/20 border border-green-900/40 rounded-xl p-4 mb-6 text-sm"
      aria-live="polite"
    >
      <span class="text-green-400 text-xl shrink-0" aria-hidden="true">🌍</span>
      <div>
        <p class="text-green-400 font-mono font-semibold text-sm">
          Tu hora local: <span id="tz-local-name"></span>
        </p>
        <p class="text-slate-500 text-xs mt-0.5">
          Los horarios de esta tabla corresponden a <strong class="text-slate-400">{ciudad.nombre} ({ciudad.abbr}, {ciudad.offsetLabel})</strong>
        </p>
      </div>
    </div>

    <!-- Aviso orientativo -->
    <div class="flex gap-3 items-start bg-slate-800/40 border border-slate-700/40 rounded-xl p-4 mb-8 text-sm">
      <span class="text-lg shrink-0" aria-hidden="true">ℹ️</span>
      <p class="text-slate-400 leading-relaxed">
        <strong class="text-slate-300">Horarios orientativos.</strong> Proyecciones basadas en los formatos de turnos habituales de la FIFA.
        El calendario oficial completo se publicará cuando FIFA confirme el fixture definitivo.
        Todas las horas: <strong class="text-white">{ciudad.abbr} ({ciudad.offsetLabel})</strong>.
      </p>
    </div>

    <!-- ─── FILTROS ───────────────────────────────────────────────────────── -->
    <div class="mb-8 flex flex-wrap gap-2" role="group" aria-label="Filtrar partidos">
      {[
        { id: 'todos',  label: 'Todos los partidos' },
        { id: 'hoy',    label: 'Hoy' },
        { id: 'manana', label: 'Mañana' },
        { id: 'grupos', label: 'Fase de Grupos' },
        { id: 'elim',   label: 'Eliminatorias' },
      ].map((f, i) => (
        <button
          data-filter={f.id}
          aria-pressed={i === 0 ? 'true' : 'false'}
          class={[
            'px-4 py-2 rounded-full text-sm font-semibold border transition-all',
            i === 0
              ? 'bg-gold text-slate-950 border-gold'
              : 'bg-slate-800 text-slate-400 border-slate-700 hover:text-white hover:border-slate-500',
          ].join(' ')}
        >
          {f.label}
        </button>
      ))}
    </div>

    <!-- No results message (hidden by default) -->
    <div
      id="no-results"
      class="hidden text-center py-10 text-slate-600 font-mono text-sm border border-slate-800 rounded-2xl mb-8"
      aria-live="polite"
    >
      No hay partidos para este filtro en este momento.
      <br /><button data-filter="todos" class="text-gold hover:underline mt-2 inline-block">Ver todos →</button>
    </div>

    <!-- ═══════════════════════════════════════════════════
         TABLA AEROPUERTO — FASE DE GRUPOS
    ════════════════════════════════════════════════════ -->
    <section aria-labelledby="grupos-heading" class="mb-4">
      <h2
        id="grupos-heading"
        class="font-oswald font-bold text-xl sm:text-2xl text-white mb-4 flex items-center gap-2"
      >
        <span
          class="w-1 h-6 rounded inline-block"
          style="background: linear-gradient(180deg,#f5d97a,#d4af37);"
          aria-hidden="true"
        ></span>
        Fase de Grupos — {ciudad.nombre}
      </h2>

      <AdSlot slot="5566778899" format="horizontal" label="Publicidad" />

      <div class="overflow-x-auto rounded-2xl border border-slate-800 mt-4 mb-2">
        <table class="w-full text-sm border-collapse" style="background: #0a0f1e;">
          <caption class="sr-only">
            Horarios Fase de Grupos — Mundial FIFA 2026 en {ciudad.nombre} ({ciudad.abbr})
          </caption>
          <thead>
            <tr class="border-b border-slate-800">
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase whitespace-nowrap">Fecha</th>
              <th scope="col" class="px-3 py-3 text-center font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase whitespace-nowrap">{ciudad.abbr}</th>
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase">Partido</th>
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase hidden md:table-cell">Sede</th>
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase hidden lg:table-cell">Fase</th>
              <th scope="col" class="px-3 py-3 text-right font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase whitespace-nowrap">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {partidosGrupos.map((p, i) => (
              <tr
                data-fecha={p.fechaISO}
                data-grupo="grupos"
                class={[
                  'border-b border-slate-800/60 transition-colors',
                  p.esDestacado
                    ? 'bg-green-950/30 hover:bg-green-950/50'
                    : i % 2 === 0
                      ? 'hover:bg-slate-800/40'
                      : 'bg-slate-900/40 hover:bg-slate-800/40',
                ].join(' ')}
              >
                <td class="px-3 py-3 whitespace-nowrap">
                  {p.esDestacado && (
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-400 mr-1.5 align-middle" aria-hidden="true"></span>
                  )}
                  <span class="font-mono text-xs text-slate-400">{p.diaFecha}</span>
                </td>
                <td class="px-3 py-3 text-center">
                  <span class={`font-mono font-bold text-base ${p.esDestacado ? 'text-green-300' : 'text-green-400'}`}>
                    {p.hora}
                  </span>
                </td>
                <td class="px-3 py-3">
                  <span class="whitespace-nowrap">
                    <span aria-hidden="true">{p.flag1}</span>
                    <span class="mx-1 text-xs font-semibold text-white">{p.equipo1}</span>
                  </span>
                  <span class="text-slate-600 mx-1 text-xs font-mono">vs</span>
                  <span class="whitespace-nowrap">
                    <span class="mx-1 text-xs font-semibold text-white">{p.equipo2}</span>
                    <span aria-hidden="true">{p.flag2}</span>
                  </span>
                </td>
                <td class="px-3 py-3 font-mono text-slate-500 text-xs hidden md:table-cell whitespace-nowrap">
                  {p.ciudadSede}
                </td>
                <td class="px-3 py-3 hidden lg:table-cell whitespace-nowrap">
                  <span class="bg-slate-800 text-slate-400 text-[10px] font-oswald tracking-wider px-2 py-0.5 rounded">
                    {p.fase}
                  </span>
                </td>
                <td class="px-3 py-3 text-right whitespace-nowrap">
                  <div class="flex items-center justify-end gap-1.5">
                    <a
                      href={gcalLink(p.fechaISO, p.horaUTC, p.equipo1, p.equipo2, p.fase, p.sede, p.ciudadSede)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center text-slate-500 hover:text-white border border-slate-700/60 hover:border-slate-500 p-1.5 rounded-lg transition-all"
                      aria-label={`Añadir ${p.equipo1} vs ${p.equipo2} a Google Calendar`}
                      title="Añadir a Google Calendar"
                    >
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="2"/>
                        <line x1="16" y1="2" x2="16" y2="6" stroke-width="2"/>
                        <line x1="8" y1="2" x2="8" y2="6" stroke-width="2"/>
                        <line x1="3" y1="10" x2="21" y2="10" stroke-width="2"/>
                      </svg>
                    </a>
                    <a
                      href={`/sedes/${p.sedeSlug}`}
                      class="text-gold hover:text-gold/80 text-xs font-mono font-bold transition-colors"
                      aria-label={`Detalles de la sede ${p.ciudadSede}`}
                    >
                      Sede →
                    </a>
                  </div>
                </td>
              </tr>
            ))}

            <!-- ── IN-FEED AD ROW ── -->
            <tr data-ad="true" data-grupo="grupos" class="border-b border-slate-800/60 border-dashed">
              <td colspan={6} class="px-0 py-0">
                <div class="relative">
                  <span class="absolute top-1 right-3 text-[9px] font-mono text-slate-700 uppercase tracking-wider z-10">Publicidad</span>
                  <AdSlot slot="6677889900" format="leaderboard" label="" />
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         TABLA AEROPUERTO — ELIMINATORIAS
    ════════════════════════════════════════════════════ -->
    <section class="mt-10" aria-labelledby="elim-heading">
      <h2
        id="elim-heading"
        class="font-oswald font-bold text-xl sm:text-2xl text-white mb-4 flex items-center gap-2"
      >
        <span
          class="w-1 h-6 rounded inline-block"
          style="background: linear-gradient(180deg,#f5d97a,#d4af37);"
          aria-hidden="true"
        ></span>
        Fases Eliminatorias — {ciudad.nombre}
      </h2>
      <p class="text-slate-500 text-sm mb-4 font-mono">
        Ronda de 32 · Octavos · Cuartos · Semifinales · Final — 4 al 19 jul 2026
      </p>

      <AdSlot slot="7788990012" format="horizontal" label="Publicidad" />

      <div class="overflow-x-auto rounded-2xl border border-slate-800 mt-4 mb-2">
        <table class="w-full text-sm border-collapse" style="background: #0a0f1e;">
          <caption class="sr-only">
            Horarios Fases Eliminatorias — Mundial FIFA 2026 en {ciudad.nombre} ({ciudad.abbr})
          </caption>
          <thead>
            <tr class="border-b border-slate-800">
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase whitespace-nowrap">Fecha</th>
              <th scope="col" class="px-3 py-3 text-center font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase whitespace-nowrap">{ciudad.abbr}</th>
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase">Partido</th>
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase hidden md:table-cell">Sede</th>
              <th scope="col" class="px-3 py-3 text-left font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase hidden sm:table-cell">Ronda</th>
              <th scope="col" class="px-3 py-3 text-right font-oswald text-[10px] tracking-[0.2em] text-slate-500 uppercase whitespace-nowrap">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {partidosElim.map((p, i) => {
              const isFinal = p.id === 'f01';
              return (
                <tr
                  data-fecha={p.fechaISO}
                  data-grupo="eliminatorias"
                  class={[
                    'border-b border-slate-800/60 transition-colors',
                    isFinal
                      ? 'bg-gold/10 hover:bg-gold/15'
                      : p.esDestacado
                        ? 'bg-green-950/30 hover:bg-green-950/50'
                        : i % 2 === 0
                          ? 'hover:bg-slate-800/40'
                          : 'bg-slate-900/40 hover:bg-slate-800/40',
                  ].join(' ')}
                >
                  <td class="px-3 py-3 whitespace-nowrap">
                    {isFinal && <span class="text-gold mr-1 text-sm" aria-hidden="true">🏆</span>}
                    <span class={`font-mono text-xs ${isFinal ? 'text-gold' : 'text-slate-400'}`}>{p.diaFecha}</span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class={`font-mono font-bold text-base ${isFinal ? 'text-gold' : p.esDestacado ? 'text-green-300' : 'text-green-400'}`}>
                      {p.hora}
                    </span>
                  </td>
                  <td class="px-3 py-3">
                    <span class="whitespace-nowrap">
                      <span aria-hidden="true">{p.flag1}</span>
                      <span class={`mx-1 text-xs font-semibold ${isFinal ? 'text-gold' : 'text-white'}`}>{p.equipo1}</span>
                    </span>
                    <span class="text-slate-600 mx-1 text-xs font-mono">vs</span>
                    <span class="whitespace-nowrap">
                      <span class={`mx-1 text-xs font-semibold ${isFinal ? 'text-gold' : 'text-white'}`}>{p.equipo2}</span>
                      <span aria-hidden="true">{p.flag2}</span>
                    </span>
                  </td>
                  <td class="px-3 py-3 font-mono text-slate-500 text-xs hidden md:table-cell whitespace-nowrap">
                    {p.ciudadSede}
                  </td>
                  <td class="px-3 py-3 hidden sm:table-cell whitespace-nowrap">
                    <span class={`text-[10px] font-oswald tracking-wider px-2 py-0.5 rounded ${isFinal ? 'bg-gold/20 text-gold' : 'bg-slate-800 text-slate-400'}`}>
                      {p.fase}
                    </span>
                  </td>
                  <td class="px-3 py-3 text-right whitespace-nowrap">
                    <div class="flex items-center justify-end gap-1.5">
                      <a
                        href={gcalLink(p.fechaISO, p.horaUTC, p.equipo1, p.equipo2, p.fase, p.sede, p.ciudadSede)}
                        target="_blank"
