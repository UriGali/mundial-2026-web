  { pais: 'argentina', ciudad: 'buenos-aires',     nombre: 'Buenos Aires',     paisNombre: 'Argentina', flag: '🇦🇷' },
  { pais: 'argentina', ciudad: 'cordoba',          nombre: 'Córdoba',          paisNombre: 'Argentina', flag: '🇦🇷' },
  { pais: 'usa',       ciudad: 'nueva-york',       nombre: 'Nueva York',       paisNombre: 'EE. UU.',   flag: '🇺🇸' },
  { pais: 'usa',       ciudad: 'los-angeles',      nombre: 'Los Ángeles',      paisNombre: 'EE. UU.',   flag: '🇺🇸' },
  { pais: 'usa',       ciudad: 'chicago',          nombre: 'Chicago',          paisNombre: 'EE. UU.',   flag: '🇺🇸' },
  { pais: 'colombia',  ciudad: 'bogota',           nombre: 'Bogotá',           paisNombre: 'Colombia',  flag: '🇨🇴' },
  { pais: 'colombia',  ciudad: 'medellin',         nombre: 'Medellín',         paisNombre: 'Colombia',  flag: '🇨🇴' },
];

// ── SEO metadata ───────────────────────────────────────────────────────────────
const title       = `Horarios Mundial 2026 en ${ciudad.nombre}, ${pais.nombre} — Hora Local (${ciudad.offsetLabel})`;
const description = `¿A qué hora son los partidos del Mundial 2026 en ${ciudad.nombre}? Tabla completa con los horarios convertidos a ${ciudad.abbr} (${ciudad.offsetLabel}). Fase de Grupos y Fases Eliminatorias con horario local exacto.`;
const canonicalURL = `https://mundial2026guia.com/horarios/${pais.slug}/${ciudad.slug}`;

// ── JSON-LD: FAQPage + BreadcrumbList ─────────────────────────────────────────
const finalConv  = horaLocal('2026-07-19', '22:00', tz, loc);
const estelarConv = horaLocal('2026-06-11', '22:00', tz, loc);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',   item: 'https://mundial2026guia.com/' },
        { '@type': 'ListItem', position: 2, name: 'Horarios', item: 'https://mundial2026guia.com/horarios' },
        { '@type': 'ListItem', position: 3, name: pais.nombre, item: `https://mundial2026guia.com/horarios/${pais.slug}` },
        { '@type': 'ListItem', position: 4, name: ciudad.nombre, item: canonicalURL },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: `¿A qué hora es la final del Mundial 2026 en ${ciudad.nombre}?`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `La final del Mundial 2026 se juega el domingo 19 de julio de 2026 a las ${finalConv.hora} ${ciudad.abbr} (22:00 UTC) en el MetLife Stadium de Nueva York, EE. UU.`,
          },
        },
        {
          '@type': 'Question',
          name: `¿En qué horario se ven los partidos nocturnos del Mundial desde ${ciudad.nombre}?`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Los partidos estelares (22:00 UTC) se transmiten a las ${estelarConv.hora} ${ciudad.abbr} en ${ciudad.nombre}. ${ciudad.nombre} opera en ${ciudad.offsetLabel} durante el verano boreal (junio–julio 2026).`,
          },
        },
        {
          '@type': 'Question',
          name: `¿Cuántas horas de diferencia hay entre UTC y ${ciudad.nombre} durante el Mundial 2026?`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Durante el Mundial 2026 (junio–julio 2026), ${ciudad.nombre} opera en ${ciudad.abbr} (${ciudad.offsetLabel} respecto a UTC). Para convertir: hora UTC ${ciudad.offsetLabel.startsWith('UTC+') ? '+' : ''}${ciudad.offsetLabel.replace('UTC', '').replace('−', '-')} horas = hora local en ${ciudad.nombre}.`,
          },
        },
      ],
    },
  ],
};
---

<Layout {title} {description} {canonicalURL} {jsonLd}>

  <!-- ===================================================
       HERO
  ==================================================== -->
  <section
    class="bg-navy-900 text-white py-14 sm:py-20 px-4"
    aria-labelledby="page-heading"
  >
    <div class="max-w-4xl mx-auto text-center">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-gray-500 flex justify-center" aria-label="Migas de pan">
        <ol class="flex items-center gap-1.5 flex-wrap justify-center">
          <li><a href="/" class="hover:text-gold transition-colors">Inicio</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li><a href="/horarios" class="hover:text-gold transition-colors">Horarios</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li><a href={`/horarios/${pais.slug}`} class="hover:text-gold transition-colors">{pais.nombre}</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li class="text-gray-400" aria-current="page">{ciudad.nombre}</li>
        </ol>
      </nav>

      <span class="text-5xl mb-3 block" role="img" aria-label={pais.nombre}>{pais.flag}</span>

      <h1 id="page-heading" class="font-black text-3xl sm:text-5xl leading-tight mb-3">
        Horarios del Mundial 2026<br class="hidden sm:block" />
        <span class="text-gold"> en {ciudad.nombre}</span>
      </h1>

      <p class="text-gray-400 text-base sm:text-lg mb-8">
        {pais.nombre} &middot; Zona horaria: <strong class="text-white">{ciudad.abbr} ({ciudad.offsetLabel})</strong>
      </p>

      <!-- Chips de conversión rápida -->
      <div class="flex flex-wrap justify-center gap-3">
        {refTable.map(r => (
          <div class="bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-center min-w-[100px]">
            <p class="text-xs text-gray-400 mb-0.5">{r.horaUTC} UTC</p>
            <p class="font-black text-gold text-lg leading-none">{r.local}</p>
            <p class="text-xs text-gray-500 mt-0.5">{r.etiqueta}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================
       CONTENIDO PRINCIPAL
  ==================================================== -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Aviso horarios referenciales -->
    <div class="flex gap-3 items-start bg-blue-50 border border-blue-200 rounded-xl p-4 mb-10 text-sm">
      <span class="text-xl shrink-0" aria-hidden="true">ℹ️</span>
      <p class="text-blue-800 leading-relaxed">
        <strong>Horarios orientativos.</strong> Los partidos mostrados son proyecciones representativas basadas en los formatos de turnos habituales de la FIFA. El calendario oficial completo se publicará cuando FIFA confirme el fixture definitivo. Todas las horas están convertidas a <strong>{ciudad.abbr} ({ciudad.offsetLabel})</strong>.
      </p>
    </div>

    <!-- ─── TABLA DE CONVERSIÓN RÁPIDA ────────────────────────────────────── -->
    <section class="mb-12" aria-labelledby="ref-heading">
      <h2 id="ref-heading" class="font-black text-xl sm:text-2xl text-navy-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-gold rounded inline-block" aria-hidden="true"></span>
        Conversión de Horarios UTC → {ciudad.nombre}
      </h2>

      <div class="overflow-x-auto rounded-2xl shadow-sm border border-gray-100">
        <table class="w-full text-sm text-left border-collapse">
          <caption class="sr-only">
            Tabla de conversión de horarios UTC a hora local de {ciudad.nombre} ({ciudad.abbr}, {ciudad.offsetLabel}) para el Mundial FIFA 2026
          </caption>
          <thead class="bg-navy-900 text-white">
            <tr>
              <th scope="col" class="px-4 py-3 font-semibold">Hora del partido (UTC)</th>
              <th scope="col" class="px-4 py-3 font-semibold">Hora en {ciudad.nombre} ({ciudad.abbr})</th>
              <th scope="col" class="px-4 py-3 font-semibold hidden sm:table-cell">Franja horaria</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {refTable.map((r, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="px-4 py-3 font-mono font-bold text-navy-900">{r.horaUTC} UTC</td>
                <td class="px-4 py-3 font-black text-gold text-base">{r.local} {ciudad.abbr}</td>
                <td class="px-4 py-3 text-gray-600 hidden sm:table-cell">{r.etiqueta}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ===================================================
         TABLA 1 — FASE DE GRUPOS
    ==================================================== -->
    <section aria-labelledby="grupos-heading">
      <h2 id="grupos-heading" class="font-black text-xl sm:text-2xl text-navy-900 mb-2 flex items-center gap-2">
        <span class="w-1 h-6 bg-gold rounded inline-block" aria-hidden="true"></span>
        Fase de Grupos — Hora en {ciudad.nombre}
      </h2>
      <p class="text-gray-500 text-sm mb-5">
        Los partidos de {pais.equipoNacional} aparecen <span class="bg-gold/20 text-navy-900 font-semibold px-1.5 rounded">resaltados en dorado</span>.
      </p>

      <!-- AdSlot ARRIBA de la tabla de grupos -->
      <AdSlot slot="5566778899" format="horizontal" label="Publicidad" />

      <div class="overflow-x-auto rounded-2xl shadow-sm border border-gray-100 mb-6">
        <table class="w-full text-sm border-collapse">
          <caption class="text-left px-4 py-2 text-xs text-gray-500 bg-gray-50 border-b border-gray-100">
            Horarios Fase de Grupos — Mundial FIFA 2026 en {ciudad.nombre} ({ciudad.abbr}, {ciudad.offsetLabel})
          </caption>
          <thead class="bg-navy-900 text-white">
            <tr>
              <th scope="col" class="px-3 py-3 text-left font-semibold whitespace-nowrap">Fecha</th>
              <th scope="col" class="px-3 py-3 text-center font-semibold whitespace-nowrap">Hora {ciudad.abbr}</th>
              <th scope="col" class="px-3 py-3 text-left font-semibold">Partido</th>
              <th scope="col" class="px-3 py-3 text-left font-semibold hidden md:table-cell">Sede</th>
              <th scope="col" class="px-3 py-3 text-left font-semibold hidden lg:table-cell">Fase</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {partidosGrupos.map((p, i) => (
              <tr class={[
                p.esDestacado ? 'bg-gold/10 font-semibold' : (i % 2 === 0 ? 'bg-white' : 'bg-gray-50'),
                'hover:bg-gold/5 transition-colors',
              ].join(' ')}>
                <td class="px-3 py-3 whitespace-nowrap text-gray-700">
                  {p.esDestacado && <span class="inline-block w-1.5 h-1.5 rounded-full bg-gold mr-1.5 align-middle" aria-hidden="true"></span>}
                  {p.diaFecha}
                </td>
                <td class="px-3 py-3 text-center">
                  <span class={`font-black text-base ${p.esDestacado ? 'text-navy-900' : 'text-gold'}`}>{p.hora}</span>
                </td>
                <td class="px-3 py-3">
                  <span class="whitespace-nowrap">
                    <span aria-hidden="true">{p.flag1}</span>
                    <span class="mx-1 text-xs font-medium">{p.equipo1}</span>
                  </span>
                  <span class="text-gray-400 mx-1 text-xs font-bold">vs</span>
                  <span class="whitespace-nowrap">
                    <span class="mx-1 text-xs font-medium">{p.equipo2}</span>
                    <span aria-hidden="true">{p.flag2}</span>
                  </span>
                </td>
                <td class="px-3 py-3 text-gray-500 text-xs hidden md:table-cell whitespace-nowrap">
                  {p.ciudadSede}
                </td>
                <td class="px-3 py-3 text-gray-500 text-xs hidden lg:table-cell whitespace-nowrap">
                  {p.fase}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- AdSlot ABAJO de la tabla de grupos -->
      <AdSlot slot="6677889900" format="rectangle" label="Publicidad" class="max-w-2xl mx-auto" />
    </section>

    <!-- ===================================================
         TABLA 2 — FASES ELIMINATORIAS
    ==================================================== -->
    <section class="mt-12" aria-labelledby="elim-heading">
      <h2 id="elim-heading" class="font-black text-xl sm:text-2xl text-navy-900 mb-2 flex items-center gap-2">
        <span class="w-1 h-6 bg-gold rounded inline-block" aria-hidden="true"></span>
        Fases Eliminatorias — Hora en {ciudad.nombre}
      </h2>
      <p class="text-gray-500 text-sm mb-5">
        Ronda de 32, Octavos, Cuartos, Semifinales y Gran Final del 4 al 19 de julio de 2026.
      </p>

      <!-- AdSlot ARRIBA de la tabla eliminatorias -->
      <AdSlot slot="7788990012" format="horizontal" label="Publicidad" />

      <div class="overflow-x-auto rounded-2xl shadow-sm border border-gray-100 mb-6">
        <table class="w-full text-sm border-collapse">
          <caption class="text-left px-4 py-2 text-xs text-gray-500 bg-gray-50 border-b border-gray-100">
            Horarios Fases Eliminatorias — Mundial FIFA 2026 en {ciudad.nombre} ({ciudad.abbr}, {ciudad.offsetLabel})
          </caption>
          <thead class="bg-navy-900 text-white">
            <tr>
              <th scope="col" class="px-3 py-3 text-left font-semibold whitespace-nowrap">Fecha</th>
              <th scope="col" class="px-3 py-3 text-center font-semibold whitespace-nowrap">Hora {ciudad.abbr}</th>
              <th scope="col" class="px-3 py-3 text-left font-semibold">Partido</th>
              <th scope="col" class="px-3 py-3 text-left font-semibold hidden md:table-cell">Sede</th>
              <th scope="col" class="px-3 py-3 text-left font-semibold hidden sm:table-cell">Ronda</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {partidosElim.map((p, i) => {
              const isFinal = p.id === 'f01';
              return (
                <tr class={[
                  isFinal        ? 'bg-gold/20 font-bold'     :
                  p.esDestacado  ? 'bg-gold/10 font-semibold' :
                  i % 2 === 0    ? 'bg-white'                  : 'bg-gray-50',
                  'hover:bg-gold/5 transition-colors',
                ].join(' ')}>
                  <td class="px-3 py-3 whitespace-nowrap text-gray-700">
                    {isFinal && <span class="text-gold mr-1" aria-hidden="true">🏆</span>}
                    {p.diaFecha}
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class={`font-black text-base ${isFinal ? 'text-navy-900' : p.esDestacado ? 'text-navy-900' : 'text-gold'}`}>
                      {p.hora}
                    </span>
                  </td>
                  <td class="px-3 py-3">
                    <span class="whitespace-nowrap">
                      <span aria-hidden="true">{p.flag1}</span>
                      <span class="mx-1 text-xs">{p.equipo1}</span>
                    </span>
                    <span class="text-gray-400 mx-1 text-xs font-bold">vs</span>
                    <span class="whitespace-nowrap">
                      <span class="mx-1 text-xs">{p.equipo2}</span>
                      <span aria-hidden="true">{p.flag2}</span>
                    </span>
                  </td>
                  <td class="px-3 py-3 text-gray-500 text-xs hidden md:table-cell whitespace-nowrap">
                    {p.ciudadSede}
                  </td>
                  <td class="px-3 py-3 text-xs hidden sm:table-cell whitespace-nowrap">
                    <span class={isFinal ? 'text-gold font-black' : 'text-gray-500'}>
                      {p.fase}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
          <tfoot>
            <tr class="bg-navy-950 text-white text-xs">
              <td colspan={5} class="px-4 py-2.5 text-center">
                <strong>Final:</strong> 19 julio 2026 &middot; MetLife Stadium, Nueva York &middot;
                {horaLocal('2026-07-19','22:00', tz, loc).hora} {ciudad.abbr}
              </td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- AdSlot ABAJO de la tabla eliminatorias -->
      <AdSlot slot="8899001122" format="rectangle" label="Publicidad" class="max-w-2xl mx-auto" />
    </section>

    <!-- ───────────────────────────────────────────────────────────────────── -->
    <!-- FAQ DESTACADA (visualmente + structured data ya en JSON-LD)          -->
    <!-- ───────────────────────────────────────────────────────────────────── -->
    <section class="mt-14 mb-12" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="font-black text-xl sm:text-2xl text-navy-900 mb-6 flex items-center gap-2">
        <span class="w-1 h-6 bg-gold rounded inline-block" aria-hidden="true"></span>
        Preguntas frecuentes — Horarios en {ciudad.nombre}
      </h2>

      <dl class="space-y-4">
        {[
          {
            pregunta: `¿A qué hora es la final del Mundial 2026 en ${ciudad.nombre}?`,
            respuesta: `La final del Mundial 2026 se disputará el domingo 19 de julio de 2026 a las ${horaLocal('2026-07-19','22:00',tz,loc).hora} ${ciudad.abbr} en el MetLife Stadium de Nueva York. El horario UTC es las 22:00.`,
          },
          {
            pregunta: `¿Cuál es la franja horaria más difícil para ver el Mundial desde ${ciudad.nombre}?`,
            respuesta: `Los partidos nocturno-nocturnos (01:00 UTC) corresponden a las ${horaLocal('2026-06-12','01:00',tz,loc).hora} ${ciudad.abbr} en ${ciudad.nombre}. ${['CEST','CET'].includes(ciudad.abbr) ? 'Para España, los partidos nocturnos americanos (9pm EDT) se juegan a las 03:00 CEST, lo que implica trasnochar.' : 'Planifica el sueño en consecuencia para los partidos de máxima noche en USA.'} `,
          },
          {
            pregunta: `¿Cuántas horas de diferencia hay entre UTC y ${ciudad.nombre} durante el Mundial?`,
            respuesta: `Durante el Mundial FIFA 2026 (junio–julio 2026), ${ciudad.nombre} opera en ${ciudad.abbr} (${ciudad.offsetLabel} UTC). Para convertir cualquier hora UTC: aplica ${ciudad.offsetLabel} horas a la hora indicada en UTC.`,
          },
        ].map(({ pregunta, respuesta }) => (
          <div class="bg-gray-50 rounded-2xl border border-gray-100 overflow-hidden">
            <dt class="px-5 py-4 font-bold text-navy-900 text-sm sm:text-base cursor-default">
              {pregunta}
            </dt>
            <dd class="px-5 pb-4 text-gray-600 text-sm leading-relaxed border-t border-gray-100">
              {respuesta}
            </dd>
          </div>
        ))}
      </dl>
    </section>

  </div>

  <!-- ===================================================
       INTERLINKING — LAS 16 SEDES
  ==================================================== -->
  <section class="bg-navy-900 text-white py-14 px-4 sm:px-6 lg:px-8" aria-labelledby="sedes-heading">
    <div class="max-w-5xl mx-auto">
      <h2 id="sedes-heading" class="font-black text-xl sm:text-2xl mb-2 text-center">
        Las 16 Sedes del Mundial 2026
      </h2>
      <p class="text-gray-400 text-sm text-center mb-8">
        Consulta información de cada estadio, transporte y Fan Zone
      </p>

      <!-- Agrupar por país -->
      {[
        { paisNombre: 'México',   paisFlag: '🇲🇽', sedes: sedesAll.filter(s => s.pais === 'México')   },
        { paisNombre: 'EE. UU.', paisFlag: '🇺🇸', sedes: sedesAll.filter(s => s.pais === 'EE. UU.') },
        { paisNombre: 'Canadá',  paisFlag: '🇨🇦', sedes: sedesAll.filter(s => s.pais === 'Canadá')  },
      ].map(grupo => (
        <div class="mb-6">
          <p class="text-xs uppercase tracking-widest text-gold mb-3">
            {grupo.paisFlag} {grupo.paisNombre}
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
            {grupo.sedes.map(s => (
              <a
                href={`/sedes/${s.slug}`}
                class="bg-white/10 hover:bg-gold/20 hover:border-gold border border-white/10 rounded-xl p-3 transition-all group"
                aria-label={`Sede ${s.ciudad}: ${s.estadio}`}
              >
                <p class="font-semibold text-white text-xs group-hover:text-gold transition-colors leading-snug">{s.ciudad}</p>
                <p class="text-gray-500 text-xs mt-0.5 leading-snug">{s.estadio}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================================================
       INTERLINKING — HORARIOS EN OTROS PAÍSES
  ==================================================== -->
  <section class="py-14 px-4 sm:px-6 lg:px-8 bg-gray-50" aria-labelledby="otros-paises-heading">
    <div class="max-w-5xl mx-auto">
      <h2 id="otros-paises-heading" class="font-black text-xl sm:text-2xl text-navy-900 mb-2 text-center">
        Horarios del Mundial 2026 en otros países
      </h2>
      <p class="text-gray-500 text-sm text-center mb-8">
        Consulta los horarios convertidos a la zona horaria de tu ciudad
      </p>

      <!-- Ciudades vecinas (los 4 países configurados en vecinos) -->
      <div class="mb-8">
        <p class="text-xs font-bold text-gold uppercase tracking-widest mb-3">Países destacados</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {pais.vecinos.map(v => (
            <a
              href={`/horarios/${v.pais}/${v.ciudad}`}
              class="flex items-center gap-2.5 bg-white border border-gray-200 hover:border-gold hover:shadow-md rounded-xl p-3.5 transition-all group"
            >
              <span class="text-2xl" aria-hidden="true">{v.flag}</span>
              <div>
                <p class="font-bold text-navy-900 text-xs group-hover:text-gold transition-colors">{v.paisNombre}</p>
                <p class="text-gray-500 text-xs">{v.nombre}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Todas las ciudades disponibles -->
      <div>
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Todas las ciudades disponibles</p>
        <div class="flex flex-wrap gap-2">
          {todasLasCiudadesHorarios
            .filter(c => !(c.pais === pais.slug && c.ciudad === ciudad.slug))
            .map(c => (
              <a
                href={`/horarios/${c.pais}/${c.ciudad}`}
                class="inline-flex items-center gap-1.5 bg-white border border-gray-200 hover:border-gold hover:text-gold text-gray-700 text-xs font-medium px-3 py-2 rounded-full transition-all shadow-sm"
              >
                <span aria-hidden="true">{c.flag}</span>
                {c.nombre}
                <span class="text-gray-400">({c.paisNombre})</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

</Layout>
