// ── Google Calendar link (UTC times, 2h duration) ─────────────────────────────
function gcalLink(fechaISO: string, horaUTC: string, e1: string, e2: string, fase: string, sede: string, ciudadSede: string): string {
  const [y, mo, d] = fechaISO.split('-').map(Number);
  const [hr, min]  = horaUTC.split(':').map(Number);
  const start      = new Date(Date.UTC(y, mo - 1, d, hr, min));
  const end        = new Date(start.getTime() + 7_200_000);
  const p2  = (n: number) => String(n).padStart(2, '0');
  const fmt = (dt: Date) =>
    `${dt.getUTCFullYear()}${p2(dt.getUTCMonth()+1)}${p2(dt.getUTCDate())}T${p2(dt.getUTCHours())}${p2(dt.getUTCMinutes())}00Z`;
  return [
    'https://calendar.google.com/calendar/render?action=TEMPLATE',
    `&text=${encodeURIComponent(`${e1} vs ${e2} — Mundial 2026`)}`,
    `&dates=${fmt(start)}/${fmt(end)}`,
    `&details=${encodeURIComponent(`${fase}\n${sede}, ${ciudadSede}\nMundial FIFA 2026`)}`,
    `&location=${encodeURIComponent(`${sede}, ${ciudadSede}`)}`,
  ].join('');
}

// ── Helper: convertir hora UTC → timezone local ────────────────────────────────
function horaLocal(fechaISO: string, horaUTC: string, timezone: string, locale: string) {
  const [y, m, d]   = fechaISO.split('-').map(Number);
  const [hr, min]   = horaUTC.split(':').map(Number);
  const utcDate     = new Date(Date.UTC(y, m - 1, d, hr, min));

  const hora = new Intl.DateTimeFormat(locale, {
    timeZone: timezone, hour: '2-digit', minute: '2-digit', hour12: false,
  }).format(utcDate);

  const diaCorto = new Intl.DateTimeFormat(locale, {
    timeZone: timezone, weekday: 'short',
  }).format(utcDate);

  const fechaCorta = new Intl.DateTimeFormat(locale, {
    timeZone: timezone, day: 'numeric', month: 'short',
  }).format(utcDate);

  return { hora, dia: diaCorto, fecha: fechaCorta, diaFecha: `${diaCorto} ${fechaCorta}` };
}

