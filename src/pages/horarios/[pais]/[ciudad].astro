// ── Helper: convertir hora UTC → timezone local ────────────────────────────────
function horaLocal(fechaISO: string, horaUTC: string, timezone: string, locale: string) {
  const [y, m, d]   = fechaISO.split('-').map(Number);
  const [hr, min]   = horaUTC.split(':').map(Number);
  const utcDate     = new Date(Date.UTC(y, m - 1, d, hr, min));

  const hora = new Intl.DateTimeFormat(locale, {
    timeZone: timezone, hour: '2-digit', minute: '2-digit', hour12: false,
  }).format(utcDate);

  const diaCorto = new Intl.DateTimeFormat(locale, {
    timeZone: timezone, weekday: 'short',
  }).format(utcDate);

  const fechaCorta = new Intl.DateTimeFormat(locale, {
    timeZone: timezone, day: 'numeric', month: 'short',
  }).format(utcDate);

  return { hora, dia: diaCorto, fecha: fechaCorta, diaFecha: `${diaCorto} ${fechaCorta}` };
}

