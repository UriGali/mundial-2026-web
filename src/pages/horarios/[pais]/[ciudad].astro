<!-- ── Client-side: TZ banner + filter pills ──────────────────────────────────── -->
<script>
  (function () {
    // Show timezone banner
    const tz     = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const banner = document.getElementById('tz-banner') as HTMLElement | null;
    const tzName = document.getElementById('tz-local-name') as HTMLElement | null;
    if (tzName) tzName.textContent = tz;
    if (banner) { banner.style.display = 'flex'; }

    // Date helpers — get today/tomorrow in user's LOCAL timezone as YYYY-MM-DD
    function localDateStr(offset: number): string {
      const d = new Date();
      d.setDate(d.getDate() + offset);
      return d.toLocaleDateString('en-CA', { timeZone: tz }); // en-CA gives YYYY-MM-DD
    }

    const todayStr    = localDateStr(0);
    const tomorrowStr = localDateStr(1);

    const allRows   = Array.from(document.querySelectorAll<HTMLElement>('[data-fecha]'));
    const adRows    = Array.from(document.querySelectorAll<HTMLElement>('[data-ad="true"]'));
    const pills     = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const noResults = document.getElementById('no-results') as HTMLElement | null;

    function applyFilter(filter: string) {
      let visible = 0;

      allRows.forEach(row => {
        const fecha = row.dataset.fecha!;
        const grupo = row.dataset.grupo!;

        let show = false;
        if      (filter === 'todos')  show = true;
        else if (filter === 'hoy')    show = fecha === todayStr;
        else if (filter === 'manana') show = fecha === tomorrowStr;
        else if (filter === 'grupos') show = grupo === 'grupos';
        else if (filter === 'elim')   show = grupo === 'eliminatorias';

        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      // Ad rows: only show when all groups or grupos filter active
      adRows.forEach(row => {
        row.style.display = (filter === 'todos' || filter === 'grupos') ? '' : 'none';
      });

      if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    }

    function setActivePill(activeFilter: string) {
      pills.forEach(p => {
        const isActive = p.dataset.filter === activeFilter;
        p.setAttribute('aria-pressed', String(isActive));
        if (isActive) {
          p.classList.remove('bg-slate-800', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:border-slate-500');
          p.classList.add('bg-gold', 'text-slate-950', 'border-gold');
        } else {
          p.classList.remove('bg-gold', 'text-slate-950', 'border-gold');
          p.classList.add('bg-slate-800', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:border-slate-500');
        }
      });
    }

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter!;
        setActivePill(filter);
        applyFilter(filter);
      });
    });

    // Apply initial state
    applyFilter('todos');
  })();
</script>
