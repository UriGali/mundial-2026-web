---
import Layout from '../layouts/Layout.astro';

const title       = 'Política de Cookies — Mundial 2026 Guía';
const description = 'Política de cookies de mundial2026guia.com. Qué cookies usamos, para qué y cómo puedes gestionarlas o desactivarlas.';
const canonicalURL = 'https://mundial2026guia.com/cookies';
const fechaActualizacion = '13 de mayo de 2026';

const cookies = [
  {
    nombre: '_ga, _ga_XXXXXXXX',
    proveedor: 'Google Analytics',
    tipo: 'Analítica',
    duracion: '2 años',
    descripcion: 'Distingue usuarios únicos y sesiones. Envía datos de comportamiento de navegación a Google Analytics para análisis de audiencia.',
  },
  {
    nombre: 'IDE',
    proveedor: 'Google DoubleClick',
    tipo: 'Publicidad',
    duracion: '13 meses',
    descripcion: 'Usada por Google AdSense para registrar y reportar las acciones del usuario después de ver o hacer clic en un anuncio. Permite medir la eficacia publicitaria.',
  },
  {
    nombre: 'test_cookie',
    proveedor: 'Google DoubleClick',
    tipo: 'Publicidad',
    duracion: '15 minutos',
    descripcion: 'Cookie de prueba para verificar si el navegador del usuario acepta cookies. No recoge datos personales.',
  },
  {
    nombre: 'CONSENT',
    proveedor: 'Google',
    tipo: 'Funcional',
    duracion: '2 años',
    descripcion: 'Almacena el estado del consentimiento de cookies del usuario para el dominio de Google.',
  },
  {
    nombre: 'NID',
    proveedor: 'Google',
    tipo: 'Publicidad',
    duracion: '6 meses',
    descripcion: 'Registra una ID única para personalizar anuncios de Google. Se usa en el contexto de AdSense.',
  },
];

const tiposClass: Record<string, string> = {
  'Analítica':  'bg-blue-100 text-blue-800',
  'Publicidad': 'bg-orange-100 text-orange-800',
  'Funcional':  'bg-green-100 text-green-800',
  'Técnica':    'bg-gray-100 text-gray-800',
};
---

<Layout {title} {description} {canonicalURL} noindex={false}>

  <!-- Hero -->
  <section class="bg-navy-900 text-white py-14 px-4" aria-labelledby="cookies-heading">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold font-bold text-xs uppercase tracking-widest mb-3">Legal</p>
      <h1 id="cookies-heading" class="font-black text-3xl sm:text-4xl mb-3">Política de Cookies</h1>
      <p class="text-gray-400 text-sm">Última actualización: {fechaActualizacion}</p>
    </div>
  </section>

  <!-- Contenido -->
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-14 text-gray-700 space-y-10">

    <section aria-labelledby="que-son">
      <h2 id="que-son" class="font-black text-xl text-navy-900 mb-3">¿Qué son las cookies?</h2>
      <p class="leading-relaxed">
        Las cookies son pequeños archivos de texto que los sitios web almacenan en tu dispositivo (ordenador, tablet o móvil) cuando los visitas. Permiten que el sitio recuerde tus acciones y preferencias (como idioma, tamaño de fuente u otras configuraciones) durante un período de tiempo, de modo que no tengas que volver a configurarlas cada vez que lo visites o navegues de una página a otra.
      </p>
    </section>

    <section aria-labelledby="que-usamos">
      <h2 id="que-usamos" class="font-black text-xl text-navy-900 mb-3">Cookies que utilizamos</h2>
      <p class="leading-relaxed mb-5 text-sm">
        Este sitio web (<strong>mundial2026guia.com</strong>) utiliza cookies propias y de terceros. A continuación encontrarás un listado detallado:
      </p>

      <!-- Tabla de cookies -->
      <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-navy-900 text-white">
              <th class="text-left p-3 font-semibold">Cookie</th>
              <th class="text-left p-3 font-semibold">Proveedor</th>
              <th class="text-left p-3 font-semibold">Tipo</th>
              <th class="text-left p-3 font-semibold">Duración</th>
              <th class="text-left p-3 font-semibold">Función</th>
            </tr>
          </thead>
          <tbody>
            {cookies.map((c, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="p-3 font-mono text-xs font-bold text-navy-900 align-top">{c.nombre}</td>
                <td class="p-3 text-xs align-top whitespace-nowrap">{c.proveedor}</td>
                <td class="p-3 align-top">
                  <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${tiposClass[c.tipo] ?? 'bg-gray-100 text-gray-800'}`}>
                    {c.tipo}
                  </span>
                </td>
                <td class="p-3 text-xs align-top whitespace-nowrap">{c.duracion}</td>
                <td class="p-3 text-xs text-gray-600 leading-relaxed align-top">{c.descripcion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section aria-labelledby="tipos-cookies">
      <h2 id="tipos-cookies" class="font-black text-xl text-navy-900 mb-4">Tipos de cookies por finalidad</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
          <p class="font-bold text-blue-900 text-sm mb-1">Cookies analíticas</p>
          <p class="text-blue-800 text-xs leading-relaxed">Nos permiten contar las visitas y conocer las fuentes de tráfico para medir y mejorar el rendimiento del Sitio. Usamos Google Analytics.</p>
        </div>
        <div class="bg-orange-50 border border-orange-200 rounded-xl p-4">
          <p class="font-bold text-orange-900 text-sm mb-1">Cookies publicitarias</p>
          <p class="text-orange-800 text-xs leading-relaxed">Usadas por Google AdSense para personalizar la publicidad según tus intereses y medir la efectividad de los anuncios mostrados.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
          <p class="font-bold text-green-900 text-sm mb-1">Cookies funcionales</p>
          <p class="text-green-800 text-xs leading-relaxed">Permiten recordar tus preferencias de consentimiento y otras configuraciones para ofrecerte una experiencia más personalizada.</p>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
          <p class="font-bold text-gray-900 text-sm mb-1">Cookies técnicas</p>
          <p class="text-gray-700 text-xs leading-relaxed">Estrictamente necesarias para el funcionamiento básico del Sitio. No requieren consentimiento. No almacenan información personal identificable.</p>
        </div>
      </div>
    </section>

    <section aria-labelledby="gestionar">
      <h2 id="gestionar" class="font-black text-xl text-navy-900 mb-3">Cómo gestionar las cookies</h2>
      <p class="leading-relaxed mb-4 text-sm">
        Puedes controlar y/o eliminar las cookies en cualquier momento. La mayoría de los navegadores web permiten controlar las cookies a través de sus configuraciones. A continuación encontrarás instrucciones para los navegadores más populares:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
        {[
          { browser: 'Google Chrome',  url: 'https://support.google.com/chrome/answer/95647' },
          { browser: 'Mozilla Firefox', url: 'https://support.mozilla.org/es/kb/habilitar-y-deshabilitar-cookies-sitios-web-rastrear-preferencias' },
          { browser: 'Safari (Mac/iOS)', url: 'https://support.apple.com/es-es/guide/safari/sfri11471/mac' },
          { browser: 'Microsoft Edge', url: 'https://support.microsoft.com/es-es/microsoft-edge/eliminar-las-cookies-en-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09' },
        ].map(({ browser, url }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 bg-white border border-gray-200 hover:border-gold hover:text-gold rounded-xl px-4 py-3 transition-colors text-gray-700"
          >
            <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            {browser}
          </a>
        ))}
      </div>

      <div class="mt-5 bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm">
        <p class="font-bold text-amber-900 mb-1">Importante</p>
        <p class="text-amber-800">
          Si bloqueas o eliminas las cookies de terceros (Google), los anuncios que veas pueden dejar de ser personalizados y algunos elementos del Sitio pueden no funcionar correctamente. Las cookies técnicas no se pueden desactivar sin afectar al funcionamiento básico del Sitio.
        </p>
      </div>
    </section>

    <section aria-labelledby="publi-personalizada">
      <h2 id="publi-personalizada" class="font-black text-xl text-navy-900 mb-3">Desactivar la publicidad personalizada de Google</h2>
      <p class="leading-relaxed text-sm">
        Puedes desactivar específicamente el uso de cookies por parte de Google para publicidad personalizada visitando el <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer" class="text-gold hover:underline">Centro de preferencias de anuncios de Google</a> o la herramienta de exclusión de <a href="https://optout.networkadvertising.org" target="_blank" rel="noopener noreferrer" class="text-gold hover:underline">Network Advertising Initiative</a>.
      </p>
    </section>

    <section aria-labelledby="actualizaciones-cookies">
      <h2 id="actualizaciones-cookies" class="font-black text-xl text-navy-900 mb-3">Actualizaciones de esta política</h2>
      <p class="leading-relaxed text-sm">
        Podemos actualizar esta Política de Cookies periódicamente para reflejar cambios en las cookies que utilizamos o por otros motivos operativos, legales o reglamentarios. Te recomendamos revisar esta página regularmente para mantenerte informado sobre nuestro uso de cookies.
      </p>
    </section>

  </article>

  <!-- Navegación legal -->
  <div class="border-t border-gray-100 bg-gray-50 py-8 px-4">
    <div class="max-w-3xl mx-auto flex flex-wrap justify-center gap-3">
      <a href="/privacidad" class="text-sm text-gray-600 hover:text-gold transition-colors px-4 py-2 bg-white border border-gray-200 rounded-full">Política de Privacidad</a>
      <a href="/aviso-legal" class="text-sm text-gray-600 hover:text-gold transition-colors px-4 py-2 bg-white border border-gray-200 rounded-full">Aviso Legal</a>
      <a href="/contacto"   class="text-sm text-gray-600 hover:text-gold transition-colors px-4 py-2 bg-white border border-gray-200 rounded-full">Contacto</a>
      <a href="/"           class="text-sm font-bold text-navy-900 hover:text-gold transition-colors px-4 py-2 bg-white border border-gray-200 rounded-full">← Volver al Inicio</a>
    </div>
  </div>

</Layout>
