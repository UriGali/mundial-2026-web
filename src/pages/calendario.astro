  { id:'f01', fechaISO:'2026-07-19', horaUTC:'22:00', e1:'Por definir',  f1:'🏆',  e2:'Por definir',  f2:'🏆',  sede:'MetLife Stadium',        ciudad:'Nueva York',    sedeSlug:'nueva-york',       fase:'🏆 GRAN FINAL', grupo:'eliminatorias' },
];

// ── Google Calendar link generator ────────────────────────────────────────────
function gcalLink(fechaISO: string, horaUTC: string, e1: string, e2: string, fase: string, sede: string, ciudad: string): string {
  const [y, mo, d]  = fechaISO.split('-').map(Number);
  const [hr, min]   = horaUTC.split(':').map(Number);
  const start       = new Date(Date.UTC(y, mo - 1, d, hr, min));
  const end         = new Date(start.getTime() + 7_200_000);
  const p2 = (n: number) => String(n).padStart(2, '0');
  const fmt = (dt: Date) =>
    `${dt.getUTCFullYear()}${p2(dt.getUTCMonth()+1)}${p2(dt.getUTCDate())}T${p2(dt.getUTCHours())}${p2(dt.getUTCMinutes())}00Z`;
  return [
    'https://calendar.google.com/calendar/render?action=TEMPLATE',
    `&text=${encodeURIComponent(`${e1} vs ${e2} — Mundial 2026`)}`,
    `&dates=${fmt(start)}/${fmt(end)}`,
    `&details=${encodeURIComponent(`${fase}\n${sede}, ${ciudad}\nMundial FIFA 2026`)}`,
    `&location=${encodeURIComponent(`${sede}, ${ciudad}`)}`,
  ].join('');
}

// ── Fase color mapping ─────────────────────────────────────────────────────────
function faseColor(fase: string): string {
  if (fase.includes('FINAL'))   return 'bg-gold/20 text-gold border-gold/30';
  if (fase.includes('Semi'))    return 'bg-red-900/40 text-red-300 border-red-800/40';
  if (fase.includes('Cuarto'))  return 'bg-orange-900/40 text-orange-300 border-orange-800/40';
  if (fase.includes('Octavo'))  return 'bg-purple-900/40 text-purple-300 border-purple-800/40';
  if (fase.includes('Ronda'))   return 'bg-blue-900/40 text-blue-300 border-blue-800/40';
  return 'bg-slate-800/60 text-slate-400 border-slate-700/40';
}

// ── Group matches by date ──────────────────────────────────────────────────────
const matchesByDate = new Map<string, typeof partidos>();
for (const p of partidos) {
  if (!matchesByDate.has(p.fechaISO)) matchesByDate.set(p.fechaISO, []);
  matchesByDate.get(p.fechaISO)!.push(p);
}
const sortedDates = [...matchesByDate.keys()].sort();

// ── Calendar grid builder (Monday-first) ──────────────────────────────────────
function buildCalendar(year: number, month: number): (number | null)[] {
  const firstDow   = new Date(year, month, 1).getDay(); // 0=Sun
  const offset     = firstDow === 0 ? 6 : firstDow - 1; // Mon=0 ... Sun=6
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const cells: (number | null)[] = [];
  for (let i = 0; i < offset; i++) cells.push(null);
  for (let d = 1; d <= daysInMonth; d++) cells.push(d);
  while (cells.length % 7 !== 0) cells.push(null);
  return cells;
}

const JUNE_CELLS = buildCalendar(2026, 5); // June (month index 5)
const JULY_CELLS = buildCalendar(2026, 6); // July (month index 6)
const WEEKDAYS   = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];

function isoDate(year: number, month1: number, day: number): string {
  return `${year}-${String(month1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
}

// ── Locale date helpers (server-side, Astro build timezone = UTC) ──────────────
const MONTH_ES: Record<number, string> = {
  1:'enero',2:'febrero',3:'marzo',4:'abril',5:'mayo',6:'junio',
  7:'julio',8:'agosto',9:'septiembre',10:'octubre',11:'noviembre',12:'diciembre',
};
const DOW_ES: Record<number, string> = {
  0:'Dom',1:'Lun',2:'Mar',3:'Mié',4:'Jue',5:'Vie',6:'Sáb',
};

function formatFecha(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  const dow = new Date(y, m - 1, d).getDay();
  return `${DOW_ES[dow]} ${d} de ${MONTH_ES[m]}`;
}

// ── JSON-LD ────────────────────────────────────────────────────────────────────
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',    item: 'https://mundial26horarios.com/' },
        { '@type': 'ListItem', position: 2, name: 'Calendario', item: canonicalURL },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Cuándo empieza el Mundial 2026?',
          acceptedAnswer: { '@type': 'Answer', text: 'El Mundial FIFA 2026 comienza el jueves 11 de junio de 2026 con el partido inaugural México vs Ecuador en el Estadio Azteca de Ciudad de México.' },
        },
        {
          '@type': 'Question',
          name: '¿Cuándo es la Final del Mundial 2026?',
          acceptedAnswer: { '@type': 'Answer', text: 'La Gran Final del Mundial 2026 es el domingo 19 de julio de 2026 en el MetLife Stadium de Nueva York (East Rutherford, Nueva Jersey) a las 22:00 UTC.' },
        },
        {
          '@type': 'Question',
          name: '¿Cuántos partidos por día hay en el Mundial 2026?',
          acceptedAnswer: { '@type': 'Answer', text: 'En la Fase de Grupos hay días con hasta 3 partidos simultáneos. En las eliminatorias se juegan 1-2 partidos por jornada. En total hay 104 partidos en 39 días de torneo.' },
        },
      ],
    },
  ],
};
