<script>
  // Convierte horas UTC a la zona horaria local del visitante
  document.querySelectorAll<HTMLElement>('.cal-time[data-utc]').forEach(el => {
    try {
      const d = new Date(el.dataset.utc!);
      el.textContent = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
    } catch (_) {}
  });
</script>
