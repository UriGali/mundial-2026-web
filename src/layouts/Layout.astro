---
import LastUpdated from '../components/LastUpdated.astro';
import Ticker      from '../components/Ticker.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonicalURL?: string;
  jsonLd?: object;
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = 'mundial 2026, copa del mundo 2026, world cup 2026, FIFA 2026, mundial USA Mexico Canada, entradas mundial 2026, sedes mundial 2026',
  ogImage = '/og-image.jpg',
  canonicalURL = Astro.url.href,
  jsonLd,
  noindex = false,
} = Astro.props;

const ADSENSE_PUB_ID = 'ca-pub-5075297176017527';
const siteURL    = Astro.site ?? new URL('https://mundial26horarios.com');
const ogImageURL = new URL(ogImage, siteURL).href;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-D3XY9RGZXV"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-D3XY9RGZXV');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta name="google-site-verification" content="9B0zB292V9CgDxYVaIgnuPswe7veqpi0byE1ihvbd6Y" />
    <meta name="theme-color" content="#020617" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={keywords} />
    <link rel="canonical"    href={canonicalURL} />

    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />
    <meta property="og:image:alt"   content={title} />
    <meta property="og:site_name"   content="Mundial 2026 — Guía para Fans" />
    <meta property="og:locale"      content="es_ES" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUB_ID}`}
      crossorigin="anonymous"
    ></script>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>

  <body class="bg-slate-950 font-inter antialiased text-slate-100">

    <!-- ===== HEADER ===== -->
    <header class="sticky top-0 z-50">

      <!-- Barra principal de navegación -->
      <div
        class="border-b border-gold/20 shadow-[0_1px_0_rgba(212,175,55,0.1)]"
        style="background: rgba(2,6,23,0.96); backdrop-filter: blur(20px);"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-2.5 group" aria-label="Mundial 2026 – Inicio">
              <div class="relative">
                <span class="text-2xl" aria-hidden="true">⚽</span>
                <span
                  class="absolute -top-0.5 -right-0.5 w-2 h-2 bg-gold rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
                  aria-hidden="true"
                ></span>
              </div>
              <span class="font-oswald font-bold text-xl tracking-wider leading-none">
                <span
                  class="bg-clip-text text-transparent"
                  style="background-image: linear-gradient(105deg, #b8922a 0%, #d4af37 40%, #f5d97a 60%, #d4af37 80%, #b8922a 100%);"
                >MUNDIAL</span>
                <span class="text-white"> 2026</span>
              </span>
            </a>

            <!-- Nav desktop -->
            <nav class="hidden md:flex items-center gap-0.5" aria-label="Navegación principal">
              {[
                { href: '/sedes',     label: 'Sedes' },
                { href: '/equipos',   label: 'Equipos' },
                { href: '/entradas',  label: 'Entradas' },
                { href: '/calendario',label: 'Calendario' },
                { href: '/grupos',    label: 'Grupos' },
                { href: '/noticias',  label: 'Noticias' },
              ].map(({ href, label }) => (
                <a
                  href={href}
                  class="relative px-3.5 py-2 text-sm font-medium text-slate-400 hover:text-gold transition-colors duration-200 group"
                >
                  {label}
                  <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-gold group-hover:w-3/4 transition-all duration-300 rounded-full" aria-hidden="true"></span>
                </a>
              ))}
              <a
                href="/blog/guia-completa"
                class="ml-2 px-5 py-2 text-sm font-bold rounded-full text-slate-950 transition-all duration-200 shadow-gold-sm hover:shadow-gold hover:scale-105"
                style="background-image: linear-gradient(105deg,#b8922a 0%,#d4af37 40%,#f5d97a 60%,#d4af37 80%,#b8922a 100%);"
              >
                Guía Completa
              </a>
            </nav>

            <!-- Botón menú móvil -->
            <button
              id="menu-toggle"
              class="md:hidden p-2 rounded-lg text-slate-400 hover:text-gold hover:bg-white/5 transition-colors border border-transparent hover:border-gold/20"
              aria-expanded="false"
              aria-controls="mobile-nav"
              aria-label="Abrir menú"
            >
              <svg id="icon-open"  class="w-6 h-6"        fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>

          <!-- Menú móvil -->
          <nav
            id="mobile-nav"
            class="md:hidden hidden border-t border-white/10 py-3"
            aria-label="Navegación móvil"
          >
            {[
              { href: '/sedes',      label: 'Sedes' },
              { href: '/equipos',    label: 'Equipos' },
              { href: '/entradas',   label: 'Entradas' },
              { href: '/calendario', label: 'Calendario' },
              { href: '/grupos',     label: 'Grupos' },
              { href: '/noticias',   label: 'Noticias' },
            ].map(({ href, label }) => (
              <a href={href} class="block px-3 py-2.5 text-sm text-slate-400 hover:text-gold hover:bg-white/5 rounded-lg transition-colors">
                {label}
              </a>
            ))}
            <a
              href="/blog/guia-completa"
              class="block mt-2 mx-3 text-center px-5 py-2.5 text-sm font-bold rounded-full text-slate-950"
              style="background-image: linear-gradient(105deg,#b8922a 0%,#d4af37 50%,#f5d97a 70%,#b8922a 100%);"
            >
              Guía Completa →
            </a>
          </nav>
        </div>
      </div>

      <!-- Ticker de noticias -->
      <Ticker />
    </header>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="bg-slate-950 border-t border-white/5 mt-20">

      <!-- Línea decorativa dorada -->
      <div class="h-px w-full" style="background: linear-gradient(90deg, transparent, #d4af37 30%, #f5d97a 50%, #d4af37 70%, transparent);"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

          <!-- Marca -->
          <div class="lg:col-span-1">
            <a href="/" class="flex items-center gap-2 mb-5">
              <span class="text-xl" aria-hidden="true">⚽</span>
              <span class="font-oswald font-bold text-lg tracking-wider">
                <span
                  class="bg-clip-text text-transparent"
                  style="background-image: linear-gradient(105deg,#b8922a,#d4af37,#f5d97a,#d4af37,#b8922a);"
                >MUNDIAL</span>
                <span class="text-white"> 2026</span>
              </span>
            </a>
            <p class="text-sm leading-relaxed text-slate-500">
              La guía definitiva para el Mundial FIFA 2026. Sedes, equipos, entradas y todo lo que necesitas saber.
            </p>
          </div>

          <!-- Sedes -->
          <div>
            <h3 class="font-oswald text-xs uppercase tracking-[0.2em] text-gold mb-5">Países Sede</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/sedes/ciudad-de-mexico" class="text-slate-500 hover:text-gold transition-colors flex items-center gap-2"><span>🇺🇸</span>Estados Unidos (11 ciudades)</a></li>
              <li><a href="/sedes/ciudad-de-mexico" class="text-slate-500 hover:text-gold transition-colors flex items-center gap-2"><span>🇲🇽</span>México (3 ciudades)</a></li>
              <li><a href="/sedes/vancouver"         class="text-slate-500 hover:text-gold transition-colors flex items-center gap-2"><span>🇨🇦</span>Canadá (2 ciudades)</a></li>
            </ul>
          </div>

          <!-- Información -->
          <div>
            <h3 class="font-oswald text-xs uppercase tracking-[0.2em] text-gold mb-5">Información</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/entradas"   class="text-slate-500 hover:text-gold transition-colors">Guía de Entradas</a></li>
              <li><a href="/calendario" class="text-slate-500 hover:text-gold transition-colors">Calendario de Partidos</a></li>
              <li><a href="/equipos"    class="text-slate-500 hover:text-gold transition-colors">Equipos Clasificados</a></li>
              <li><a href="/grupos"     class="text-slate-500 hover:text-gold transition-colors">Grupos y Fase Final</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="font-oswald text-xs uppercase tracking-[0.2em] text-gold mb-5">Legal</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/sobre-nosotros" class="text-slate-500 hover:text-gold transition-colors">Sobre Nosotros</a></li>
              <li><a href="/privacidad"     class="text-slate-500 hover:text-gold transition-colors">Política de Privacidad</a></li>
              <li><a href="/cookies"        class="text-slate-500 hover:text-gold transition-colors">Política de Cookies</a></li>
              <li><a href="/aviso-legal"    class="text-slate-500 hover:text-gold transition-colors">Aviso Legal</a></li>
              <li><a href="/contacto"       class="text-slate-500 hover:text-gold transition-colors">Contacto</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Barra inferior -->
      <div class="border-t border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-slate-600">
          <div class="flex flex-col sm:flex-row items-center gap-3">
            <p>© 2026 mundial26horarios.com — Sitio informativo independiente. No afiliado con FIFA™.</p>
            <LastUpdated />
          </div>
          <div class="flex gap-4 shrink-0">
            <a href="/privacidad"  class="hover:text-gold transition-colors">Privacidad</a>
            <a href="/aviso-legal" class="hover:text-gold transition-colors">Aviso Legal</a>
            <a href="/cookies"     class="hover:text-gold transition-colors">Cookies</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Toggle menú móvil -->
    <script>
      const toggle    = document.getElementById('menu-toggle');
      const nav       = document.getElementById('mobile-nav');
      const iconOpen  = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const opening = nav?.classList.contains('hidden');
        nav?.classList.toggle('hidden', !opening);
        toggle.setAttribute('aria-expanded', String(opening));
        iconOpen?.classList.toggle('hidden',  opening);
        iconClose?.classList.toggle('hidden', !opening);
      });
    </script>
  </body>
</html>
